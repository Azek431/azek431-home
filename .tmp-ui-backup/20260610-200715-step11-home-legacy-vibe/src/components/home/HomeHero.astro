---
type FocusItem = {
  title: string;
  desc: string;
};

type SiteConfig = {
  github: string;
};

type Props = {
  todayDate: string;
  pageCount: number;
  siteConfig: SiteConfig;
  focusItems: FocusItem[];
};

const { todayDate, pageCount, siteConfig, focusItems } = Astro.props as Props;
---

<section class="home-v3-hero" aria-labelledby="home-v3-title">
  <div class="home-v3-copy">
    <p class="home-v3-kicker">
      <span></span>
      Build {todayDate} · {pageCount} pages · Astro / Cloudflare
    </p>

    <h1 id="home-v3-title">
      <span>Azek431</span>
      <span>Digital Nexus</span>
    </h1>

    <p class="home-v3-lead">
      一个持续进化的个人数字中枢。用于连接项目、AI 实验、学习记录与公开入口。
    </p>

    <div class="home-v3-actions" aria-label="首页主要操作">
      <a class="ui-button ui-button-primary" href="/projects/" aria-label="查看 Azek431 的项目列表">
        查看项目
      </a>
      <a
        class="ui-button ui-button-secondary"
        href={siteConfig.github}
        target="_blank"
        rel="noreferrer"
        aria-label="在新窗口打开 Azek431 的 GitHub 主页"
      >
        GitHub
      </a>
      <button class="ui-button ui-button-ghost" type="button" data-copy-url> 复制主页链接 </button>
    </div>

    <div class="home-v3-tracks" aria-label="站点关注方向">
      {
        focusItems.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <span>{item.desc}</span>
          </article>
        ))
      }
    </div>
  </div>

  <slot />
</section>

<script is:inline>
  (function () {
    var button = document.querySelector('[data-copy-url]');
    if (!button) return;

    var defaultText = button.textContent || '复制主页链接';

    button.addEventListener('click', function () {
      var url = window.location.href;

      if (!navigator.clipboard) {
        button.textContent = url;
        window.setTimeout(function () {
          button.textContent = defaultText;
        }, 1600);
        return;
      }

      navigator.clipboard
        .writeText(url)
        .then(function () {
          button.textContent = '已复制 ✓';
        })
        .catch(function () {
          button.textContent = '复制失败';
        })
        .finally(function () {
          window.setTimeout(function () {
            button.textContent = defaultText;
          }, 1400);
        });
    });
  })();
</script>
