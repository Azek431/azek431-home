---
import { siteConfig } from '../data/site';
import { getSiteAge, siteStartedAtIso, siteStartedDateTime } from '../data/time';

const year = new Date().getFullYear();
const siteAge = getSiteAge();
---

<footer class="footer">
  <div class="footer-meta">
    <p class="footer-line">
      © {year}
      {siteConfig.name}. Built with Astro &amp; deployed on Cloudflare Pages.
    </p>
    <p class="footer-line footer-sub">
      <span
        >建站于 {siteStartedDateTime} · 已运行 <span
          class="footer-runtime"
          data-runtime
          data-started-at={siteStartedAtIso}
          aria-live="off">{siteAge.preciseLabel}</span
        ></span
      >
      <span class="dot-sep" aria-hidden="true">·</span>
      <a href="/rss.xml" target="_blank" rel="noreferrer noopener" class="footer-rss">RSS</a>
      <span class="dot-sep" aria-hidden="true">·</span>
      <a href="/sitemap.xml" target="_blank" rel="noreferrer noopener">Sitemap</a>
    </p>
  </div>
  <div class="footer-links">
    <a href="/">首页</a>
    <a href="/projects/">项目</a>
    <a href={siteConfig.github} target="_blank" rel="noreferrer noopener">GitHub</a>
    <button type="button" class="shortcut-trigger" data-shortcut-toggle aria-label="键盘快捷键提示">
      <kbd>?</kbd>
    </button>
  </div>
</footer>
<div class="shortcut-hint" role="dialog" aria-label="键盘快捷键" aria-hidden="true">
  <div class="shortcut-hint-card">
    <div class="shortcut-hint-head">
      <h3>键盘快捷键</h3>
      <button type="button" class="shortcut-hint-close" aria-label="关闭">×</button>
    </div>
    <ul>
      <li><kbd>g</kbd><kbd>h</kbd><span>首页</span></li>
      <li><kbd>g</kbd><kbd>a</kbd><span>关于</span></li>
      <li><kbd>g</kbd><kbd>p</kbd><span>项目</span></li>
      <li><kbd>g</kbd><kbd>l</kbd><span>链接</span></li>
      <li><kbd>g</kbd><kbd>n</kbd><span>Now</span></li>
      <li><kbd>g</kbd><kbd>u</kbd><span>Uses</span></li>
      <li><kbd>g</kbd><kbd>c</kbd><span>Colophon</span></li>
      <li><kbd>g</kbd><kbd>k</kbd><span>Changelog</span></li>
      <li><kbd>g</kbd><kbd>s</kbd><span>Stats</span></li>
      <li><kbd>g</kbd><kbd>b</kbd><span>Blog</span></li>
      <li><kbd>/</kbd><span>站内搜索</span></li>
      <li><kbd>t</kbd><span>切换明 / 暗主题</span></li>
      <li><kbd>r</kbd><span>随机打开一个项目</span></li>
      <li><kbd>esc</kbd><span>关闭这个面板</span></li>
      <li><kbd>?</kbd><span>显示 / 隐藏这个面板</span></li>
    </ul>
  </div>
</div>

<script is:inline>
  (function () {
    var trig = document.querySelector('[data-shortcut-toggle]');
    var hint = document.querySelector('.shortcut-hint');
    var close = document.querySelector('.shortcut-hint-close');
    if (!hint) return;
    var close2 = function () {
      hint.classList.remove('visible');
      hint.setAttribute('aria-hidden', 'true');
    };
    var open = function () {
      hint.classList.add('visible');
      hint.setAttribute('aria-hidden', 'false');
    };
    if (trig)
      trig.addEventListener('click', function () {
        hint.classList.contains('visible') ? close2() : open();
      });
    if (close) close.addEventListener('click', close2);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && hint.classList.contains('visible')) close2();
    });
  })();
</script>

<script is:inline data-runtime-script>
  (function () {
    var runtimeEl = document.querySelector('[data-runtime]');
    if (!runtimeEl) return;

    var startedAt = runtimeEl.getAttribute('data-started-at');
    var startedTime = startedAt ? new Date(startedAt).getTime() : NaN;

    if (!Number.isFinite(startedTime)) return;

    var pad = function (value) {
      return String(value).padStart(2, '0');
    };

    var renderRuntime = function () {
      var diff = Math.max(0, Date.now() - startedTime);
      var totalSeconds = Math.floor(diff / 1000);
      var days = Math.floor(totalSeconds / 86400);
      var hours = Math.floor((totalSeconds % 86400) / 3600);
      var minutes = Math.floor((totalSeconds % 3600) / 60);
      var seconds = totalSeconds % 60;

      runtimeEl.textContent =
        days + ' 天 ' + pad(hours) + ' 小时 ' + pad(minutes) + ' 分 ' + pad(seconds) + ' 秒';
    };

    renderRuntime();
    window.setInterval(renderRuntime, 1000);

    document.addEventListener('visibilitychange', function () {
      if (!document.hidden) renderRuntime();
    });
  })();
</script>
