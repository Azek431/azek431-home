---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { siteConfig } from '../data/site';
import { siteUpdatedDate } from '../data/time';

const lastUpdated = siteUpdatedDate;

const workingOn = [
  {
    title: 'Azek431 Home 主站迭代',
    detail:
      '把过去几个月累积的 UI 升级一次性整合到主站,补齐项目详情子页和站点地图,准备进入下个迭代周期。',
    status: 'in-progress',
    tag: '主站',
  },
  {
    title: '设计系统 / 设计 token 收尾',
    detail:
      '把现在 global.css 里的 design tokens 拆分成独立 css variables 文件,后续切换主题会更顺。',
    status: 'in-progress',
    tag: '设计',
  },
  {
    title: 'Blog 仓库搭建',
    detail: '准备单独建一个仓库,接主站,文章用 Markdown + Git 维护。这一轮先把入口和样式占位好。',
    status: 'planning',
    tag: '内容',
  },
  {
    title: 'AI 工作流实验',
    detail: '尝试把日常重复工作交给 AI / 自动化流程,记录提示词、小型 agent 搭建过程。',
    status: 'exploring',
    tag: 'AI',
  },
];

const recentlyRead = [
  { title: 'Designing for the Long Now', kind: 'Essay' },
  { title: 'How to write a /now page', kind: 'Post' },
  { title: 'Astro 6.4 release notes', kind: 'Changelog' },
  { title: 'Modern CSS one-line solutions', kind: 'Article' },
];

const tools = [
  { name: 'Astro', role: '主站框架', tone: 'primary' },
  { name: 'Cloudflare Pages', role: '托管 + CDN', tone: 'accent' },
  { name: 'GitHub', role: '代码 + 部署触发', tone: 'success' },
  { name: 'pnpm', role: '包管理', tone: 'muted' },
  { name: 'Prettier', role: '格式化', tone: 'muted' },
  { name: 'VS Code', role: '主力编辑器', tone: 'primary' },
];

const statusLabel = (s: string) =>
  s === 'in-progress'
    ? '进行中'
    : s === 'planning'
      ? '规划中'
      : s === 'exploring'
        ? '探索中'
        : '已完成';
const statusTone = (s: string) =>
  s === 'in-progress'
    ? 'active'
    : s === 'planning'
      ? 'next'
      : s === 'exploring'
        ? 'future'
        : 'done';
---

<BaseLayout
  title="Now - Azek431"
  description="Azek431 现在正在做的事情、最近读的内容和日常用的工具。"
>
  <Breadcrumb items={[{ label: '首页', href: '/' }, { label: 'Now' }]} />
  <section class="page-hero now-hero">
    <p class="eyebrow">Now</p>
    <h1>现在在做的事</h1>
    <p class="page-hero-text">
      这一页会记录我最近关注的方向、正在做的项目、最近读到的内容,以及日常用到的工具。
      页面会持续更新,比 About 更具体,比 Blog 更轻量。
    </p>
    <div class="now-meta">
      <span class="now-meta-item">
        <span class="now-meta-label">最近更新</span>
        <span class="now-meta-value">{lastUpdated}</span>
      </span>
      <span class="now-meta-item">
        <span class="now-meta-label">地点</span>
        <span class="now-meta-value">线上 / GitHub</span>
      </span>
      <span class="now-meta-item">
        <span class="now-meta-label">方向</span>
        <span class="now-meta-value">Web · AI · Open Source</span>
      </span>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Working On</p>
      <h2>正在进行</h2>
      <p>这 4 项是当前优先级最高的几条线,每条都标了状态和领域。</p>
    </div>

    <div class="now-list">
      {
        workingOn.map((w) => (
          <article class:list={['now-list-item', 'tone-' + statusTone(w.status)]}>
            <div class="now-list-head">
              <span class="now-list-tag">{w.tag}</span>
              <span class="now-list-status">{statusLabel(w.status)}</span>
            </div>
            <h3>{w.title}</h3>
            <p>{w.detail}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Reading</p>
      <h2>最近读到</h2>
      <p>不一定是技术内容,可能是一段有意思的讨论、一篇文章或者一份 changelog。</p>
    </div>

    <ul class="reading-list" aria-label="最近读到的内容">
      {
        recentlyRead.map((r) => (
          <li class="reading-item">
            <span class="reading-kind">{r.kind}</span>
            <span class="reading-title">{r.title}</span>
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="M5 12h14" />
                <path d="m13 5 7 7-7 7" />
              </>
            </svg>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Stack</p>
      <h2>日常工具</h2>
      <p>我日常用来搭建主站、写代码、托管和发布内容的一套工具,简洁、长期、稳定优先。</p>
    </div>

    <div class="tool-grid">
      {
        tools.map((t) => (
          <div class:list={['tool-chip', 'tone-' + t.tone]}>
            <span class="tool-name">{t.name}</span>
            <span class="tool-role">{t.role}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="now-cta">
      <h3>想了解我关注什么 / 在做什么?</h3>
      <p>关于页有更完整的介绍,链接页整理了所有公开入口,有想法也可以通过 GitHub 找到我。</p>
      <div class="actions">
        <a class="button primary" href="/about/">关于我</a>
        <a
          class="button secondary"
          href={siteConfig.github}
          target="_blank"
          rel="noreferrer noopener">GitHub</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
