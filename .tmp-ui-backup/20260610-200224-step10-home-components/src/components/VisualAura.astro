<div class="visual-aura" aria-hidden="true">
  <span class="visual-aura__orb visual-aura__orb--one"></span>
  <span class="visual-aura__orb visual-aura__orb--two"></span>
  <span class="visual-aura__orb visual-aura__orb--three"></span>
  <span class="visual-aura__liquid visual-aura__liquid--one"></span>
  <span class="visual-aura__liquid visual-aura__liquid--two"></span>
  <span class="visual-aura__ring visual-aura__ring--one"></span>
  <span class="visual-aura__ring visual-aura__ring--two"></span>
  <span class="visual-aura__grid"></span>
  <span class="visual-aura__scanner"></span>
  <span class="visual-aura__noise"></span>
  <span class="visual-aura__cursor" data-aura-cursor></span>
</div>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var cursor = document.querySelector('[data-aura-cursor]');
    var canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!canHover || reduceMotion) return;

    var raf = 0;
    var nextX = 0;
    var nextY = 0;

    var updateRootPointer = function () {
      raf = 0;
      root.style.setProperty('--aura-x', nextX + 'px');
      root.style.setProperty('--aura-y', nextY + 'px');

      if (cursor) {
        cursor.style.transform = 'translate3d(' + nextX + 'px, ' + nextY + 'px, 0)';
      }
    };

    window.addEventListener(
      'pointermove',
      function (event) {
        nextX = event.clientX;
        nextY = event.clientY;

        if (!raf) {
          raf = window.requestAnimationFrame(updateRootPointer);
        }
      },
      { passive: true },
    );

    var glassSelector = [
      '.hero-copy',
      '.hero-console',
      '.page-v2-hero',
      '.project-lab-card',
      '.resource-group-v2',
      '.resource-card-v2',
      '.quick-action-card',
      '.project-showcase-card',
      '.nexus-card',
      '.card',
      '.card-static',
      '.stats-grid-v2 article',
      '.local-stats-v2',
      '.uses-grid-v2 > article',
      '.principle-grid-v2 article',
      '.tool-grid-v2 article',
      '.blog-plan-v2 article',
      '.draft-grid-v2 article',
      '.changelog-entry-v2',
      '.project-detail-hero-v2',
      '.project-story-v2',
      '.project-tags-v2',
      '.feature-grid-v2 article',
      '.about-narrative-v2',
      '.footer-shell',
    ].join(',');

    var glassNodes = Array.prototype.slice.call(document.querySelectorAll(glassSelector));

    glassNodes.forEach(function (node) {
      node.addEventListener(
        'pointermove',
        function (event) {
          var rect = node.getBoundingClientRect();
          var x = event.clientX - rect.left;
          var y = event.clientY - rect.top;

          node.style.setProperty('--mx', x + 'px');
          node.style.setProperty('--my', y + 'px');
        },
        { passive: true },
      );
    });
  })();
</script>
