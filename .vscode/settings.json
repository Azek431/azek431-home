{
  "files.watcherPolling": "threshold",
  "files.watcherPollingDelay": 2000,
  {
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.astro/**": true,
    "**/.vite/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true,
    "**/coverage/**": true
  },

  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.astro": true,
    "**/.vite": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/coverage": true
  },

  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.astro": true,
    "**/.vite": true,
    "**/.turbo": true,
    "**/.cache": true,
    "**/coverage": true
  }
},
  "search.followSymlinks": false,
  "search.maxResults": 10000,
  "cSpell.enabled": false,
  "workbench.animations.enabled": false,
  "editor.minimap.enabled": false,
  "editor.smoothScrolling": false,
  "workbench.list.smoothScrolling": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.codeLens.enabled": false,
  "gitlens.statusBar.enabled": false,
  "code-runner.showExecutionMessage": false,
  "code-runner.saveAllFilesBeforeRun": false
}
