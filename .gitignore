# ============================================================
# azek431-home .gitignore
# ============================================================
#
# 项目类型：
# - Astro 静态网站
# - pnpm 管理依赖
# - GitHub 主仓库
# - Gitee 镜像仓库
# - Cloudflare Pages 部署
# - Windows / Linux 多设备开发
# - 可能使用 Syncthing 做文件同步或备份
#
# 这个文件的目标：
# - 忽略可以自动生成的文件
# - 忽略本机缓存和临时文件
# - 忽略系统文件和编辑器个人配置
# - 忽略 Syncthing 冲突文件和同步临时文件
# - 防止环境变量、Token、密钥等敏感信息进入公开仓库
#
# 注意：
# .gitignore 只能控制 Git 是否追踪文件。
# 它不能阻止 Syncthing 自己同步文件。
# 如果要阻止 Syncthing 同步 .git、node_modules、dist 等目录，
# 需要在 Syncthing 的忽略规则或 .stignore 中单独设置。
# ============================================================


# ============================================================
# Build output
# 构建产物
# ============================================================
#
# dist/ 是 Astro 构建后的静态网站输出目录。
# 执行 pnpm build / astro build 后会自动生成。
#
# 这个目录不需要提交：
# - 内容可以随时重新构建
# - Cloudflare Pages 部署时会自动生成
# - 提交 dist 会让仓库变大，也容易产生无意义 diff
# ============================================================

dist/


# ============================================================
# Astro / Vite generated files
# Astro / Vite 自动生成文件
# ============================================================
#
# .astro/
# - Astro 自动生成的类型文件、中间状态和开发缓存
#
# .vite/
# - Vite 开发服务器和构建缓存
#
# .cache/
# - 一些工具可能产生的通用缓存目录
#
# 这些文件都可以删除后重新生成，不属于源码。
# ============================================================

.astro/
.vite/
.cache/


# ============================================================
# Dependencies
# 依赖目录
# ============================================================
#
# node_modules/ 由 pnpm install 自动生成。
#
# 不提交原因：
# - 文件数量巨大
# - 不同系统生成内容可能不同
# - Windows / Linux / macOS 下依赖二进制可能不同
# - 通过 pnpm-lock.yaml 可以稳定恢复依赖
#
# 多设备开发时也不建议用 Syncthing 同步 node_modules。
# 每台设备单独执行 pnpm install 更稳定。
# ============================================================

node_modules/


# ============================================================
# Package manager cache
# 包管理器缓存
# ============================================================
#
# 这些目录通常是 npm / pnpm / Yarn 的本地缓存。
# 它们只属于当前机器，不属于项目源码。
# ============================================================

.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz


# ============================================================
# Logs
# 日志文件
# ============================================================
#
# 包管理器、构建工具、运行时可能生成日志。
# 日志用于本地排错，不应该进入仓库。
# ============================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ============================================================
# Environment variables
# 环境变量与敏感配置
# ============================================================
#
# .env 文件可能包含：
# - API Key
# - Token
# - 数据库地址
# - 私有域名
# - 部署密钥
# - 第三方服务凭证
#
# 公开仓库里绝对不应该提交真实 .env。
#
# 但是可以保留示例文件：
# - .env.example
# - .env.local.example
# - .env.production.example
#
# 示例文件只写变量名和说明，不写真实密钥。
# ============================================================

.env
.env.*
!.env.example
!.env.*.example


# ============================================================
# Cloudflare / deployment local files
# Cloudflare / Wrangler 本地文件
# ============================================================
#
# 当前项目主要通过 Cloudflare Pages 自动部署。
#
# 如果以后使用 Wrangler，本地可能生成：
# - .wrangler/
# - 部署缓存
# - 本地运行状态
#
# 这些文件只和本地环境有关，不需要提交。
#
# 注意：
# public/_headers 不要忽略。
# public/_headers 是 Cloudflare Pages 的正式配置文件，
# 需要提交到仓库。
# ============================================================

.wrangler/


# ============================================================
# Syncthing files
# Syncthing 同步文件
# ============================================================
#
# Syncthing 多设备同步时可能产生：
# - sync-conflict 冲突文件
# - .syncthing*.tmp 临时文件
# - *.part 未完成同步文件
# - .stversions 历史版本目录
# - .stfolder 文件夹标记
# - .stignore 同步忽略规则
#
# 这些文件都不是项目源码，不应该进入 Git。
#
# 重要提醒：
# - .gitignore 只能防止这些文件被 Git 提交
# - 它不能阻止 Syncthing 继续同步它们
# - 如果你想真正避免冲突，应该在 Syncthing 中忽略：
#   .git
#   node_modules
#   dist
#   .astro
#   .vite
#   .cache
#
# 尤其不建议实时同步 .git/。
# .git 是 Git 的内部数据库，频繁变化，实时同步容易产生冲突。
# ============================================================

.stfolder/
.stversions/
.stignore

.syncthing*.tmp
.syncthing.*.tmp
*.sync-conflict*
*sync-conflict*
*.part


# ============================================================
# Windows system files
# Windows 系统文件
# ============================================================
#
# Windows 资源管理器、缩略图缓存、桌面配置、回收站等
# 可能自动生成这些文件。
# 它们和项目代码无关。
# ============================================================

Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/


# ============================================================
# macOS system files
# macOS 系统文件
# ============================================================
#
# 即使当前主要在 Windows / Linux 开发，
# 仓库公开后或以后换设备时也可能遇到 macOS。
# 提前忽略这些文件可以减少无意义变更。
# ============================================================

.DS_Store
.AppleDouble
.LSOverride


# ============================================================
# Linux desktop / temporary files
# Linux 桌面环境和临时文件
# ============================================================
#
# Linux 文件管理器、桌面环境、编辑器可能生成这些文件。
# 它们不属于项目源码。
# ============================================================

*~
.Trash-*/
.directory


# ============================================================
# Editor files
# 编辑器本地文件
# ============================================================
#
# 当前不整体忽略 .vscode/。
#
# 原因：
# - 你的项目里可以保留 .vscode/extensions.json
# - 也可以保留 .vscode/launch.json
# - 这些属于项目推荐配置，提交是合理的
#
# 但个人本地配置、临时状态、历史记录不应该提交。
# ============================================================

.idea/
.history/
*.swp
*.swo

.vscode/*.local.json
.vscode/*.local.*
.vscode/settings.local.json


# ============================================================
# TypeScript / tooling cache
# TypeScript、Lint、格式化工具缓存
# ============================================================
#
# 当前项目不一定全部用到这些工具，
# 但以后如果添加 TypeScript 检查、ESLint、Stylelint，
# 这些缓存文件不应该进入仓库。
# ============================================================

*.tsbuildinfo
.eslintcache
.stylelintcache


# ============================================================
# Test / coverage output
# 测试和覆盖率输出
# ============================================================
#
# 如果以后添加测试工具，可能产生：
# - coverage/
# - .nyc_output/
#
# 它们是测试生成物，不属于源码。
# ============================================================

coverage/
.nyc_output/


# ============================================================
# Temporary / backup files
# 临时文件、备份文件、旧文件
# ============================================================
#
# 这些通常来自：
# - 编辑器自动备份
# - 手动复制备份
# - 临时调试
# - 文件同步工具
#
# 如果某个文件确实需要长期保留，
# 建议使用明确的文件名，而不是 .bak / .old / .tmp 这类后缀。
# ============================================================

*.bak
*.old
*.temp
*.tmp

.tmp-ui-backup/
.vercel/

# Local generated files

# VitePress generated cache
.vitepress/cache/
.vitepress/dist/
# Local UI backup files
