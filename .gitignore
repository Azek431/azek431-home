# ============================================================
# Build output
# 构建产物目录，由 pnpm build / astro build 自动生成
# 不需要提交到 Git，也不需要同步到远程仓库
# ============================================================

dist/


# ============================================================
# Astro / Vite generated files
# Astro 和 Vite 自动生成的缓存、类型和中间文件
# 删除后可以自动重新生成
# ============================================================

.astro/
.vite/
.cache/


# ============================================================
# Dependencies
# 依赖目录非常大，小文件非常多
# 每台设备应该单独执行 pnpm install 生成
# ============================================================

node_modules/


# ============================================================
# Logs
# 各类包管理器、构建工具、运行时产生的日志
# ============================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ============================================================
# Environment variables
# 环境变量文件可能包含密钥、Token、API 地址等敏感信息
# 不应该提交到公开仓库
# ============================================================

.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local


# ============================================================
# Syncthing files
# Syncthing 同步时可能产生的临时文件、冲突文件和版本目录
# 这些文件不是项目源码，不能进入 Git
# ============================================================

.stfolder/
.stversions/
.stignore

.syncthing*.tmp
.syncthing.*.tmp
*.sync-conflict*
*sync-conflict*
*.tmp
*.part


# ============================================================
# Windows system files
# Windows 文件资源管理器、缩略图、桌面配置产生的系统文件
# ============================================================

Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/


# ============================================================
# macOS system files
# macOS Finder 自动生成的系统文件
# ============================================================

.DS_Store
.AppleDouble
.LSOverride


# ============================================================
# Linux temporary files
# Linux 桌面环境、编辑器或系统可能产生的临时文件
# ============================================================

*~
.Trash-*/
.directory


# ============================================================
# Editor files
# 编辑器本地缓存或个人配置
# .vscode 可以按需保留，当前不整体忽略
# ============================================================

.idea/
.history/
*.swp
*.swo


# ============================================================
# Package manager cache
# 包管理器缓存目录，一般不需要进入仓库
# ============================================================

.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz


# ============================================================
# Test / coverage output
# 测试覆盖率和测试缓存
# ============================================================

coverage/
.nyc_output/


# ============================================================
# Misc temporary files
# 其他临时、备份、旧文件
# ============================================================

*.bak
*.old
*.temp
