---
import { navItems, siteConfig } from '../data/site';

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<header class="site-header">
  <a class="logo" href="/" aria-label={`${siteConfig.name} 首页`}>
    <span class="logo-mark" aria-hidden="true">A</span>
    <span>{siteConfig.name}</span>
  </a>

  <nav class="nav" aria-label="主导航">
    {
      navItems.map((item) => (
        <a class:list={[{ active: isActive(item.href) }]} href={item.href}>
          {item.label}
        </a>
      ))
    }

    <a
      class="nav-github"
      href={siteConfig.github}
      target="_blank"
      rel="noreferrer noopener"
      aria-label="访问 GitHub"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M12 .5C5.73.5.67 5.56.67 11.83c0 5.02 3.24 9.27 7.74 10.77.57.1.78-.25.78-.55v-1.94c-3.15.69-3.81-1.52-3.81-1.52-.51-1.31-1.25-1.66-1.25-1.66-1.02-.7.08-.69.08-.69 1.13.08 1.73 1.16 1.73 1.16 1 1.72 2.64 1.22 3.28.93.1-.73.39-1.22.71-1.5-2.51-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.16-3.05-.12-.29-.5-1.44.11-2.99 0 0 .95-.3 3.11 1.16.9-.25 1.87-.38 2.83-.38.96 0 1.93.13 2.83.38 2.16-1.47 3.11-1.16 3.11-1.16.61 1.55.23 2.7.11 2.99.72.8 1.16 1.81 1.16 3.05 0 4.35-2.66 5.31-5.18 5.59.4.34.76 1.02.76 2.06v3.05c0 .3.21.66.79.55 4.5-1.5 7.73-5.74 7.73-10.77C23.33 5.56 18.27.5 12 .5Z"/>
      </svg>
      <span>GitHub</span>
    </a>
  </nav>
</header>