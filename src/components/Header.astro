---
import ThemeToggle from './ThemeToggle.astro';
import {
  moreNavigationItems,
  primaryNavigationItems,
  searchNavigationItem,
  shortcutLabelByHref,
} from '../data/navigation';
import { siteConfig } from '../data/site';

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const isMoreActive = moreNavigationItems.some((item) => isActive(item.href));
---

<header class="site-header site-header-v4" aria-label="站点顶部导航" data-site-header>
  <a class="site-header-v4__brand" href="/" aria-label={`返回 ${siteConfig.name} 首页`}>
    <span class="site-header-v4__brand-mark" aria-hidden="true"> A </span>

    <span class="site-header-v4__brand-copy">
      <strong>{siteConfig.name}</strong>
      <small>Digital Nexus</small>
    </span>
  </a>

  <nav class="site-header-v4__primary" aria-label="主要导航">
    {
      primaryNavigationItems.map((item) => (
        <a
          class:list={['site-header-v4__nav-link', isActive(item.href) && 'is-active']}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          title={item.description}
        >
          <span>{item.label}</span>

          {shortcutLabelByHref[item.href] && (
            <kbd aria-hidden="true">{shortcutLabelByHref[item.href]}</kbd>
          )}
        </a>
      ))
    }
  </nav>

  <div class="site-header-v4__actions">
    <a
      class:list={[
        'site-header-v4__action',
        'site-header-v4__search',
        isActive(searchNavigationItem.href) && 'is-active',
      ]}
      href={searchNavigationItem.href}
      aria-label={searchNavigationItem.description}
      title={`${searchNavigationItem.description} (/)`}
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.8-3.8"></path>
      </svg>

      <span>搜索</span>
      <kbd aria-hidden="true">/</kbd>
    </a>

    <div class="site-header-v4__network" aria-label="公开代码主页">
      <a
        href={siteConfig.github}
        target="_blank"
        rel="noreferrer noopener"
        aria-label="在新窗口打开 Azek431 的 GitHub 主页"
      >
        GitHub
      </a>

      <a
        class="is-gitee"
        href={siteConfig.gitee}
        target="_blank"
        rel="noreferrer noopener"
        aria-label="在新窗口打开 Azek431 的 Gitee 主页"
      >
        Gitee
      </a>
    </div>

    <ThemeToggle />

    <button
      class:list={['site-header-v4__menu-toggle', isMoreActive && 'has-active-page']}
      type="button"
      aria-label="打开完整导航"
      aria-expanded="false"
      aria-controls="site-header-navigation-panel"
      data-header-menu-toggle
    >
      <span class="site-header-v4__menu-label"> 更多 </span>

      {isMoreActive && <span class="site-header-v4__active-dot" aria-hidden="true" />}

      <span class="site-header-v4__menu-icon" aria-hidden="true">
        <i></i>
        <i></i>
        <i></i>
      </span>
    </button>
  </div>

  <div class="site-header-v4__scrim" aria-hidden="true" hidden data-header-scrim></div>

  <aside
    id="site-header-navigation-panel"
    class="site-header-v4__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="site-header-panel-title"
    aria-describedby="site-header-panel-description"
    aria-hidden="true"
    hidden
    data-header-panel
  >
    <div class="site-header-v4__panel-head">
      <div>
        <p>Navigation</p>

        <h2 id="site-header-panel-title">探索 Azek431</h2>

        <span id="site-header-panel-description"> 浏览主要页面、长期记录和公开代码入口。 </span>
      </div>

      <button
        class="site-header-v4__panel-close"
        type="button"
        aria-label="关闭完整导航"
        data-header-menu-close
      >
        <span aria-hidden="true">×</span>
      </button>
    </div>

    <div class="site-header-v4__panel-groups">
      <section class="site-header-v4__panel-group">
        <header>
          <span>01</span>

          <div>
            <h3>主要页面</h3>
            <p>网站最常用的核心入口。</p>
          </div>
        </header>

        <nav aria-label="完整主要导航">
          {
            primaryNavigationItems.map((item) => (
              <a
                class:list={['site-header-v4__panel-link', isActive(item.href) && 'is-active']}
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <span>
                  <strong>{item.label}</strong>
                  <small>{item.description}</small>
                </span>

                <kbd aria-hidden="true">{shortcutLabelByHref[item.href] ?? 'Open'}</kbd>
              </a>
            ))
          }
        </nav>
      </section>

      <section class="site-header-v4__panel-group">
        <header>
          <span>02</span>

          <div>
            <h3>更多内容</h3>
            <p>记录、统计和技术说明。</p>
          </div>
        </header>

        <nav aria-label="更多站内页面">
          {
            moreNavigationItems.map((item) => (
              <a
                class:list={['site-header-v4__panel-link', isActive(item.href) && 'is-active']}
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <span>
                  <strong>{item.label}</strong>
                  <small>{item.description}</small>
                </span>

                <kbd aria-hidden="true">{shortcutLabelByHref[item.href] ?? 'Open'}</kbd>
              </a>
            ))
          }
        </nav>
      </section>
    </div>

    <div class="site-header-v4__panel-tools">
      <a href={searchNavigationItem.href}>
        <span>
          <strong>站内搜索</strong>
          <small> 页面、项目、链接和更新记录 </small>
        </span>

        <kbd aria-hidden="true">/</kbd>
      </a>

      <a href={siteConfig.github} target="_blank" rel="noreferrer noopener">
        <span>
          <strong>GitHub</strong>
          <small>主仓库和开源项目</small>
        </span>

        <small aria-hidden="true">↗</small>
      </a>

      <a href={siteConfig.gitee} target="_blank" rel="noreferrer noopener">
        <span>
          <strong>Gitee</strong>
          <small>国内镜像与同步入口</small>
        </span>

        <small aria-hidden="true">↗</small>
      </a>
    </div>
  </aside>
</header>

<script is:inline>
  (function () {
    var header = document.querySelector('[data-site-header]');

    if (!header) return;

    if (header.getAttribute('data-navigation-ready') === 'true') {
      return;
    }

    header.setAttribute('data-navigation-ready', 'true');

    var toggle = header.querySelector('[data-header-menu-toggle]');

    var closeButton = header.querySelector('[data-header-menu-close]');

    var panel = header.querySelector('[data-header-panel]');

    var scrim = header.querySelector('[data-header-scrim]');

    if (!toggle || !closeButton || !panel || !scrim) {
      return;
    }

    var lastFocused = null;
    var closeTimer = null;

    function isOpen() {
      return toggle.getAttribute('aria-expanded') === 'true';
    }

    function getFocusableElements() {
      return Array.prototype.slice.call(
        panel.querySelectorAll(
          'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])',
        ),
      );
    }

    function dispatchOverlayOpen() {
      document.dispatchEvent(
        new CustomEvent('site:overlay-open', {
          detail: {
            source: 'header-navigation',
          },
        }),
      );
    }

    function openPanel() {
      if (isOpen()) return;

      if (closeTimer) {
        window.clearTimeout(closeTimer);
        closeTimer = null;
      }

      dispatchOverlayOpen();

      lastFocused = document.activeElement;

      panel.hidden = false;
      scrim.hidden = false;

      panel.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', '关闭完整导航');

      document.documentElement.classList.add('has-site-nav-open');

      window.requestAnimationFrame(function () {
        header.classList.add('is-menu-open');

        var focusable = getFocusableElements();

        if (focusable.length > 0) {
          focusable[0].focus();
        }
      });
    }

    function closePanel(restoreFocus) {
      if (!isOpen()) return;

      header.classList.remove('is-menu-open');

      panel.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', '打开完整导航');

      document.documentElement.classList.remove('has-site-nav-open');

      closeTimer = window.setTimeout(function () {
        if (!isOpen()) {
          panel.hidden = true;
          scrim.hidden = true;
        }

        closeTimer = null;
      }, 190);

      if (restoreFocus !== false && lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    function togglePanel() {
      if (isOpen()) {
        closePanel(true);
      } else {
        openPanel();
      }
    }

    toggle.addEventListener('click', togglePanel);

    closeButton.addEventListener('click', function () {
      closePanel(true);
    });

    scrim.addEventListener('click', function () {
      closePanel(true);
    });

    panel.addEventListener('click', function (event) {
      var target = event.target;

      if (target && target.closest && target.closest('a')) {
        closePanel(false);
      }
    });

    document.addEventListener('site:overlay-open', function (event) {
      var detail = event.detail || {};

      if (detail.source !== 'header-navigation') {
        closePanel(false);
      }
    });

    document.addEventListener('site:overlay-close-all', function () {
      closePanel(false);
    });

    document.addEventListener('keydown', function (event) {
      if (!isOpen()) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        closePanel(true);
        return;
      }

      if (event.key !== 'Tab') return;

      var focusable = getFocusableElements();

      if (focusable.length === 0) return;

      var first = focusable[0];
      var last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    window.addEventListener('pagehide', function () {
      closePanel(false);
    });
  })();
</script>
