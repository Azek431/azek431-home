---
import ThemeToggle from './ThemeToggle.astro';
import {
  moreNavigationItems,
  primaryNavigationItems,
  searchNavigationItem,
  shortcutLabelByHref,
} from '../data/navigation';
import { siteConfig } from '../data/site';

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const isMoreActive = moreNavigationItems.some((item) => isActive(item.href));
---

<header class="site-header" aria-label="站点顶部导航" data-site-header>
  <div class="site-header-inner">
    <a class="site-header__brand" href="/" aria-label={`返回 ${siteConfig.name} 首页`}>
      <span class="site-header__mark" aria-hidden="true">A</span>
      <span>{siteConfig.name}</span>
    </a>

    <nav class="site-header__nav" aria-label="主要导航">
      {
        primaryNavigationItems.map((item) => (
          <a
            class={isActive(item.href) ? 'is-active' : ''}
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            title={item.description}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions">
      <a
        class="site-header__icon-btn"
        href={searchNavigationItem.href}
        aria-label={searchNavigationItem.description}
        title={[searchNavigationItem.description, '(Slash)'].join(' ')}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.8-3.8"></path>
        </svg>
      </a>

      <div class="site-header__socials">
        <a href={siteConfig.github} target="_blank" rel="noreferrer noopener" aria-label="GitHub">GH</a>
        <a href={siteConfig.gitee} target="_blank" rel="noreferrer noopener" aria-label="Gitee">GE</a>
      </div>

      <ThemeToggle />

      <button
        class="site-header__icon-btn site-header__menu-toggle"
        type="button"
        aria-label="打开完整导航"
        aria-expanded="false"
        aria-controls="site-header-navigation-panel"
        data-header-menu-toggle
      >
        <i class="site-header__menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </i>
      </button>
    </div>
  </div>

  <!-- Full navigation panel -->
  <div class="site-header__scrim" aria-hidden="true" hidden data-header-scrim></div>

  <aside
    id="site-header-navigation-panel"
    class="site-header__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="site-header-panel-title"
    aria-hidden="true"
    hidden
    data-header-panel
  >
    <div class="site-header__panel-head">
      <div>
        <p>Navigation</p>
        <h2 id="site-header-panel-title">探索 Azek431</h2>
        <span>浏览主要页面、长期记录和公开代码入口。</span>
      </div>
      <button class="site-header__panel-close" type="button" aria-label="关闭完整导航" data-header-menu-close>
        <span aria-hidden="true">×</span>
      </button>
    </div>

    <div class="site-header__panel-groups">
      <section class="site-header__panel-group">
        <header>
          <span>01</span>
          <div>
            <h3>主要页面</h3>
            <p>网站最常用的核心入口。</p>
          </div>
        </header>
        <nav aria-label="完整主要导航">
          {
            primaryNavigationItems.map((item) => (
              <a
                class={isActive(item.href) ? 'is-active' : ''}
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <span>
                  <strong>{item.label}</strong>
                  <small>{item.description}</small>
                </span>
              </a>
            ))
          }
        </nav>
      </section>

      <section class="site-header__panel-group">
        <header>
          <span>02</span>
          <div>
            <h3>更多内容</h3>
            <p>记录、统计和技术说明。</p>
          </div>
        </header>
        <nav aria-label="更多站内页面">
          {
            moreNavigationItems.map((item) => (
              <a
                class={isActive(item.href) ? 'is-active' : ''}
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <span>
                  <strong>{item.label}</strong>
                  <small>{item.description}</small>
                </span>
              </a>
            ))
          }
        </nav>
      </section>
    </div>

    <div class="site-header__panel-tools">
      <a href={searchNavigationItem.href}>
        <span><strong>站内搜索</strong><small> 页面、项目、链接和更新记录</small></span>
      </a>
      <a href={siteConfig.github} target="_blank" rel="noreferrer noopener">
        <span><strong>GitHub</strong><small>主仓库和开源项目</small></span>
      </a>
      <a href={siteConfig.gitee} target="_blank" rel="noreferrer noopener">
        <span><strong>Gitee</strong><small>国内镜像与同步入口</small></span>
      </a>
    </div>
  </aside>
</header>

<script is:inline>
  (function () {
    var header = document.querySelector('[data-site-header]');
    if (!header) return;
    if (header.getAttribute('data-navigation-ready') === 'true') return;
    header.setAttribute('data-navigation-ready', 'true');

    var toggle = header.querySelector('[data-header-menu-toggle]');
    var closeButton = header.querySelector('[data-header-menu-close]');
    var panel = header.querySelector('[data-header-panel]');
    var scrim = header.querySelector('[data-header-scrim]');
    if (!toggle || !closeButton || !panel || !scrim) return;

    var lastFocused = null;

    function isOpen() {
      return toggle.getAttribute('aria-expanded') === 'true';
    }

    function getFocusable() {
      return Array.from(panel.querySelectorAll('a[href], button:not([disabled])'));
    }

    function openPanel() {
      if (isOpen()) return;
      lastFocused = document.activeElement;
      panel.hidden = false;
      scrim.hidden = false;
      panel.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.documentElement.classList.add('has-site-nav-open');
      requestAnimationFrame(function () {
        var focusable = getFocusable();
        if (focusable.length > 0) focusable[0].focus();
      });
    }

    function closePanel() {
      if (!isOpen()) return;
      toggle.setAttribute('aria-expanded', 'false');
      document.documentElement.classList.remove('has-site-nav-open');
      setTimeout(function () {
        if (!isOpen()) {
          panel.hidden = true;
          scrim.hidden = true;
        }
        panel.setAttribute('aria-hidden', 'true');
      }, 150);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    toggle.addEventListener('click', function () { isOpen() ? closePanel() : openPanel(); });
    closeButton.addEventListener('click', closePanel);
    scrim.addEventListener('click', closePanel);
    panel.addEventListener('click', function (e) {
      if (e.target.closest && e.target.closest('a')) closePanel(false);
    });

    document.addEventListener('keydown', function (e) {
      if (!isOpen()) return;
      if (e.key === 'Escape') { e.preventDefault(); closePanel(); return; }
      if (e.key !== 'Tab') return;
      var focusable = getFocusable();
      if (focusable.length === 0) return;
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    });
  })();
</script>

<style is:global>
  /* Panel overlay */
  .site-header__panel {
    position: fixed;
    z-index: 90;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease);
  }

  .site-header__scrim {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease);
  }

  .site-header__panel[aria-hidden="false"],
  .has-site-nav-open .site-header__panel {
    opacity: 1;
    pointer-events: auto;
  }

  .has-site-nav-open .site-header__scrim {
    opacity: 1;
    pointer-events: auto;
  }

  .site-header__panel-inner {
    width: min(560px, calc(100% - 32px));
    max-height: 80vh;
    overflow-y: auto;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
  }

  .site-header__panel-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__panel-head p {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }

  .site-header__panel-head h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-1);
  }

  .site-header__panel-head span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
    display: block;
  }

  .site-header__panel-close {
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__panel-groups {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .site-header__panel-group > header {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
    margin-bottom: var(--space-3);
  }

  .site-header__panel-group > header span {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    font-weight: 700;
  }

  .site-header__panel-group h3 {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .site-header__panel-group p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .site-header__panel-group nav a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: background var(--duration-fast) var(--ease);
  }

  .site-header__panel-group nav a:hover {
    background: var(--color-bg-subtle);
    color: var(--color-text);
  }

  .site-header__panel-group nav a.is-active {
    background: var(--color-bg-subtle);
    color: var(--color-text);
    font-weight: 600;
  }

  .site-header__panel-group nav a span {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .site-header__panel-group nav a small {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
  }

  .site-header__panel-tools {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .site-header__panel-tools a {
    display: flex;
    flex-direction: column;
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    transition: border-color var(--duration-fast) var(--ease);
  }

  .site-header__panel-tools a:hover {
    border-color: var(--color-border-strong);
  }

  .site-header__panel-tools small {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    font-weight: 400;
    margin-top: 2px;
  }

  /* Menu icon animation */
  .site-header__menu-icon {
    display: flex;
    flex-direction: column;
    gap: 3px;
    width: 16px;
  }

  .site-header__menu-icon span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: currentColor;
    border-radius: 1px;
    transition: transform var(--duration-fast) var(--ease), opacity var(--duration-fast) var(--ease);
  }

  .site-header__menu-toggle[aria-expanded="true"] .site-header__menu-icon span:first-child {
    transform: translateY(4.5px) rotate(45deg);
  }

  .site-header__menu-toggle[aria-expanded="true"] .site-header__menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .site-header__menu-toggle[aria-expanded="true"] .site-header__menu-icon span:last-child {
    transform: translateY(-4.5px) rotate(-45deg);
  }

  /* Back to top */
  .to-top {
    position: fixed;
    right: 20px;
    bottom: 20px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-raised);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease), transform var(--duration-normal) var(--ease), background var(--duration-fast) var(--ease);
    z-index: 40;
  }

  .to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .to-top:hover {
    background: var(--color-bg-subtle);
    color: var(--color-text);
  }

  @media (max-width: 760px) {
    .site-header__panel-groups {
      grid-template-columns: 1fr;
    }
    .site-header__panel-tools {
      grid-template-columns: 1fr;
    }
  }
</style>
