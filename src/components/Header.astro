---
import { navItems, siteConfig } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';

const kbdMap: Record<string, string> = {
  '/': 'g h',
  '/about/': 'g a',
  '/projects/': 'g p',
  '/links/': 'g l',
  '/now/': 'g n',
  '/uses/': 'g u',
  '/blog/': 'g b',
  '/colophon/': 'g c',
  '/changelog/': 'g k',
  '/stats/': 'g s',
  '/search/': '/',
};

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="site-header" aria-label="站点顶部导航">
  <a class="site-header__brand" href="/" aria-label={`返回 ${siteConfig.name} 首页`}>
    <span aria-hidden="true">A</span>
    <strong>{siteConfig.name}</strong>
  </a>

  <nav class="site-header__nav" aria-label="主导航">
    {
      navItems.map((item) => (
        <a
          class:list={['site-header__nav-link', isActive(item.href) && 'is-active']}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          <span>{item.label}</span>
          {kbdMap[item.href] && <kbd>{kbdMap[item.href]}</kbd>}
        </a>
      ))
    }
  </nav>

  <div class="site-header__actions">
    <div class="site-header__network" aria-label="公开代码主页入口">
      <a
        class="site-header__network-link"
        href={siteConfig.github}
        target="_blank"
        rel="noreferrer"
        aria-label="在新窗口打开 Azek431 的 GitHub 主页"
      >
        GitHub
      </a>

      <a
        class="site-header__network-link site-header__network-link--gitee"
        href={siteConfig.gitee}
        target="_blank"
        rel="noreferrer"
        aria-label="在新窗口打开 Azek431 的 Gitee 主页"
      >
        Gitee
      </a>
    </div>

    <ThemeToggle />
  </div>
</header>
