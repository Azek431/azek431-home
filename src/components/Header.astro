---
import { navItems, siteConfig } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';

const kbdMap: Record<string, string> = {
  '/': 'g h',
  '/about/': 'g a',
  '/projects/': 'g p',
  '/links/': 'g l',
  '/now/': 'g n',
  '/uses/': 'g u',
  '/blog/': 'g b',
  '/colophon/': 'g c',
  '/changelog/': 'g k',
  '/stats/': 'g s',
  '/search/': '/',
};

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<header class="site-header">
  <a class="logo" href="/" aria-label={siteConfig.name + ' 首页'}>
    <span class="logo-mark" aria-hidden="true">A</span>
    <span>{siteConfig.name}</span>
  </a>

  <ThemeToggle />

  <button class="nav-toggle" type="button" aria-label="打开菜单" aria-expanded="false" data-nav-toggle>
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>

  <nav class="nav" aria-label="主导航" data-nav>
    {
      navItems.map((item) => {
        return (
          <a class:list={['nav-link', { active: isActive(item.href) }]} href={item.href} data-kbd={kbdMap[item.href] || ''}>
            <span class="nav-link-label">{item.label}</span>
            {kbdMap[item.href] && <kbd class="nav-kbd">{kbdMap[item.href]}</kbd>}
          </a>
        );
      })
    }

    <a
      class="nav-github"
      href={siteConfig.github}
      target="_blank"
      rel="noreferrer noopener"
      aria-label="访问 GitHub"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M12 .5C5.73.5.67 5.56.67 11.83c0 5.02 3.24 9.27 7.74 10.77.57.1.78-.25.78-.55v-1.94c-3.15.69-3.81-1.52-3.81-1.52-.51-1.31-1.25-1.66-1.25-1.66-1.02-.7.08-.69.08-.69 1.13.08 1.73 1.16 1.73 1.16 1 1.72 2.64 1.22 3.28.93.1-.73.39-1.22.71-1.5-2.51-.29-5.16-1.26-5.16-5.6 0-1.24.44-2.25 1.16-3.05-.12-.29-.5-1.44.11-2.99 0 0 .95-.3 3.11 1.16.9-.25 1.87-.38 2.83-.38.96 0 1.93.13 2.83.38 2.16-1.47 3.11-1.16 3.11-1.16.61 1.55.23 2.7.11 2.99.72.8 1.16 1.81 1.16 3.05 0 4.35-2.66 5.31-5.18 5.59.4.34.76 1.02.76 2.06v3.05c0 .3.21.66.79.55 4.5-1.5 7.73-5.74 7.73-10.77C23.33 5.56 18.27.5 12 .5Z"/>
      </svg>
      <span>GitHub</span>
    </a>
  </nav>

  <div class="nav-scrim" data-nav-scrim aria-hidden="true"></div>
</header>

<script is:inline>
  (function () {
    var btn = document.querySelector('[data-nav-toggle]');
    var nav = document.querySelector('[data-nav]');
    var scrim = document.querySelector('[data-nav-scrim]');
    if (!btn || !nav) return;

    var open = function () {
      nav.classList.add('is-open');
      if (scrim) scrim.classList.add('is-open');
      btn.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', '关闭菜单');
      document.body.style.overflow = 'hidden';
    };
    var close = function () {
      nav.classList.remove('is-open');
      if (scrim) scrim.classList.remove('is-open');
      btn.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', '打开菜单');
      document.body.style.overflow = '';
    };
    btn.addEventListener('click', function () {
      if (nav.classList.contains('is-open')) close();
      else open();
    });
    if (scrim) scrim.addEventListener('click', close);
    nav.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a');
      if (a && nav.classList.contains('is-open')) {
        setTimeout(close, 80);
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && nav.classList.contains('is-open')) close();
    });
    window.addEventListener('resize', function () {
      if (window.innerWidth >= 880) close();
    });
  })();
</script>
