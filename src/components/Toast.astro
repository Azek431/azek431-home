---
interface Props {
  id?: string;
}
const { id = 'toast' } = Astro.props;
---
<div class="toast-host" id={id} aria-live="polite" aria-atomic="true"></div>

<style>
  .toast-host {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9998;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  :global(.toast-msg) {
    pointer-events: auto;
    background: var(--surface-3, #1a2236);
    color: var(--text-1, #e8eefb);
    border: 1px solid var(--border-1, rgba(168, 200, 255, 0.25));
    border-radius: 999px;
    padding: 0.55rem 1.1rem;
    font-size: 0.88rem;
    box-shadow: 0 12px 32px -10px rgba(0, 0, 0, 0.5);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    animation: toast-in 0.25s ease, toast-out 0.25s ease 1.6s forwards;
    backdrop-filter: blur(12px);
  }
  :global(.toast-msg.success) { border-color: rgba(184, 224, 194, 0.5); }
  :global(.toast-msg.info)    { border-color: rgba(168, 200, 255, 0.5); }
  :global(.toast-msg.error)   { border-color: rgba(243, 168, 200, 0.5); }
  :global(.toast-msg .toast-icon) {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    color: #b8e0c2;
  }
  :global(.toast-msg.error .toast-icon) { color: #f3a8c8; }
  :global(.toast-msg.info .toast-icon)  { color: #a8c8ff; }
  @keyframes toast-in {
    from { opacity: 0; transform: translateY(8px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes toast-out {
    to   { opacity: 0; transform: translateY(8px) scale(0.96); }
  }
</style>

<script is:inline define:vars={{ id }}>
  (function () {
    var host = document.getElementById(id);
    if (!host) return;
    window.__toast = function (msg, tone) {
      tone = tone || 'success';
      var el = document.createElement('div');
      el.className = 'toast-msg ' + tone;
      var icon = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      icon.setAttribute('class', 'toast-icon');
      icon.setAttribute('viewBox', '0 0 24 24');
      icon.setAttribute('fill', 'none');
      icon.setAttribute('stroke', 'currentColor');
      icon.setAttribute('stroke-width', '2.4');
      icon.setAttribute('stroke-linecap', 'round');
      icon.setAttribute('stroke-linejoin', 'round');
      var mark = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
      mark.setAttribute('points', '20 6 9 17 4 12');
      icon.appendChild(mark);
      var text = document.createElement('span');
      text.textContent = msg;
      el.appendChild(icon);
      el.appendChild(text);
      host.appendChild(el);
      setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 2000);
    };
  })();
</script>
