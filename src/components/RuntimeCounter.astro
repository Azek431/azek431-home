---
interface Props {
  startedAt: string;
  fallback: string;
  className?: string;
}

const { startedAt, fallback, className = '' } = Astro.props;
---

<span
  class:list={['runtime-counter', className]}
  data-runtime-counter
  data-started-at={startedAt}
  aria-live="off"
>
  {fallback}
</span>

<script is:inline>
  (function () {
    var nodes = Array.prototype.slice.call(document.querySelectorAll('[data-runtime-counter]'));

    if (!nodes.length) return;

    var pad = function (value) {
      return String(value).padStart(2, '0');
    };

    var renderNode = function (node) {
      var startedAt = node.getAttribute('data-started-at');
      var startedTime = startedAt ? new Date(startedAt).getTime() : NaN;

      if (!Number.isFinite(startedTime)) return;

      var diff = Math.max(0, Date.now() - startedTime);
      var totalSeconds = Math.floor(diff / 1000);
      var days = Math.floor(totalSeconds / 86400);
      var hours = Math.floor((totalSeconds % 86400) / 3600);
      var minutes = Math.floor((totalSeconds % 3600) / 60);
      var seconds = totalSeconds % 60;

      node.textContent =
        days + ' 天 ' + pad(hours) + ' 小时 ' + pad(minutes) + ' 分 ' + pad(seconds) + ' 秒';
    };

    var renderAll = function () {
      nodes.forEach(renderNode);
    };

    renderAll();
    window.setInterval(renderAll, 1000);

    document.addEventListener('visibilitychange', function () {
      if (!document.hidden) renderAll();
    });
  })();
</script>
