<div class="interface-fx" aria-hidden="true">
  <div class="interface-fx__progress">
    <span data-scroll-progress></span>
  </div>

  <div class="interface-fx__corner interface-fx__corner--tl"></div>
  <div class="interface-fx__corner interface-fx__corner--tr"></div>
  <div class="interface-fx__corner interface-fx__corner--bl"></div>
  <div class="interface-fx__corner interface-fx__corner--br"></div>

  <div class="interface-fx__hud">
    <span class="interface-fx__pulse"></span>
    <span>UI SYSTEM V2</span>
    <strong data-hud-percent>00%</strong>
  </div>
</div>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var progress = document.querySelector('[data-scroll-progress]');
    var hudPercent = document.querySelector('[data-hud-percent]');
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var lastScrollY = window.scrollY;

    root.classList.add('is-enhanced-ui');

    var updateScroll = function () {
      var max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
      var percent = Math.min(1, Math.max(0, window.scrollY / max));
      var text = String(Math.round(percent * 100)).padStart(2, '0') + '%';

      root.style.setProperty('--scroll-progress', String(percent));

      if (window.scrollY > 12) {
        root.classList.add('is-scrolled');
      } else {
        root.classList.remove('is-scrolled');
      }

      if (window.scrollY > lastScrollY && window.scrollY > 80) {
        root.classList.add('is-scrolling-down');
        root.classList.remove('is-scrolling-up');
      } else {
        root.classList.add('is-scrolling-up');
        root.classList.remove('is-scrolling-down');
      }

      lastScrollY = window.scrollY;

      if (progress) {
        progress.style.transform = 'scaleX(' + percent + ')';
      }

      if (hudPercent) {
        hudPercent.textContent = text;
      }
    };

    updateScroll();

    var ticking = false;

    window.addEventListener(
      'scroll',
      function () {
        if (ticking) return;
        ticking = true;

        window.requestAnimationFrame(function () {
          ticking = false;
          updateScroll();
        });
      },
      { passive: true },
    );

    window.addEventListener('resize', updateScroll, { passive: true });

    window.addEventListener('load', function () {
      root.classList.add('is-page-ready');
      updateScroll();
    });

    if (reduceMotion || !('IntersectionObserver' in window)) {
      root.classList.add('is-page-ready');
      return;
    }

    var revealSelector = [
      '.legacy-project-card',
      '.project-card-system',
      '.project-lab-card',
      '.project-showcase-card',
      '.resource-card-v2',
      '.resource-group-v2',
      '.link-card-v2',
      '.search-panel-v2',
      '.search-results-v2 li',
      '.stats-grid-v2 article',
      '.home-v3-hero',
      '.home-v3-stats article',
      '.home-v3-command',
      '.home-v3-project-main',
      '.home-v3-project-side article',
      '.home-v3-nav-grid a',
      '.home-v3-timeline a',
      '.home-v3-network',
      '.home-v3-phase-grid article',
      '.home-v2-hero',
      '.home-stats-v2 article',
      '.section-v2',
      '.quick-action-card',
      '.project-showcase-card',
      '.update-list-v2 a',
      '.nexus-card',
      '.ecosystem-grid a',
      '.page-v2-hero',
      '.project-lab-card',
      '.resource-group-v2',
      '.resource-card-v2',
      '.search-results-v2 li',
      '.stats-grid-v2 article',
      '.uses-grid-v2 > article',
      '.principle-grid-v2 article',
      '.tool-grid-v2 article',
      '.blog-plan-v2 article',
      '.draft-grid-v2 article',
      '.changelog-timeline-v2 article',
      '.project-detail-hero-v2',
      '.feature-grid-v2 article',
    ].join(',');

    var nodes = Array.prototype.slice.call(document.querySelectorAll(revealSelector));

    nodes.forEach(function (node, index) {
      node.classList.add('fx-reveal');
      node.style.setProperty('--reveal-index', String(Math.min(index, 10)));
    });

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        rootMargin: '0px 0px -8% 0px',
        threshold: 0.08,
      },
    );

    nodes.forEach(function (node) {
      observer.observe(node);
    });
  })();
</script>
