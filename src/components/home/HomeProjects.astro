---

type ProjectHighlight = {
  label: string;
  value: string;
};

type ProjectItem = {
  slug: string;
  title: string;
  description: string;
  longDescription: string;
  category: string;
  status: string;
  accent: string;
  tags: string[];
  highlights: ProjectHighlight[];
  websiteUrl?: string;
  githubUrl?: string;
  giteeUrl?: string;
};

type ProjectPreview = {
  eyebrow: string;
  title: string;
  description: string;
  navigation: {
    label: string;
    count: string;
    active?: boolean;
  }[];
  records: {
    title: string;
    type: string;
    status: string;
  }[];
};

type Props = {
  mainProject?: ProjectItem;
  sideProjects: ProjectItem[];
  preview: ProjectPreview;
};

const { mainProject, sideProjects, preview } = Astro.props as Props;

function externalProjectLinks(project: ProjectItem) {
  return [
    project.websiteUrl && { label: '访问', href: project.websiteUrl },
    project.githubUrl && { label: 'GitHub', href: project.githubUrl },
    project.giteeUrl && { label: 'Gitee', href: project.giteeUrl },
  ].filter(Boolean) as { label: string; href: string }[];
}
---

<section class="home-projects reveal" id="featured-work" aria-labelledby="home-projects-title">
  <div class="home-projects__header">
    <div>
      <p>FEATURED WORK</p>
      <h2 id="home-projects-title">正在生长的作品</h2>
    </div>
    <a href="/projects/">查看全部 →</a>
  </div>

  {
    mainProject && (
      <article class="home-projects__featured">
        <div class="home-projects__preview">
          <div class="home-projects__preview-bar">
            <>
              <span />
              <span />
              <span />
            </>
            <small>{mainProject.websiteUrl ?? mainProject.slug}</small>
          </div>
          <div class="home-projects__preview-body">
            <div style="text-align:left; width:100%;">
              <div style="display:flex; gap:8px; margin-bottom:16px;">
                <span style="font-size:0.65rem; padding:3px 8px; border-radius:999px; border:1px solid var(--color-border); color:var(--color-text-muted); background:var(--color-bg-subtle);">
                  {mainProject.status}
                </span>
              </div>
              <div style="font-size:0.85rem; font-weight:600; margin-bottom:8px;">
                {preview.title}
              </div>
              <div style="display:flex; flex-direction:column; gap:6px; margin-bottom:20px;">
                {preview.records.slice(0, 4).map((r, i) => (
                  <div style="display:flex; align-items:center; gap:8px; font-size:0.75rem; color:var(--color-text-muted);">
                    <span style="font-family:ui-monospace,monospace; color:var(--color-text-faint);">
                      0{i + 1}
                    </span>
                    <span>{r.title}</span>
                    <span style="margin-left:auto; color:var(--color-text-faint);">{r.status}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="home-projects__content">
          <div class="tags">
            <span class="tag tag-accent">{mainProject.category}</span>
            <span class="tag">{mainProject.status}</span>
          </div>
          <h3>{mainProject.title}</h3>
          <p>{mainProject.longDescription || mainProject.description}</p>
          <div class="actions">
            <a class="button button-primary" href={`/projects/${mainProject.slug}/`}>
              <span>项目详情</span>
              <span aria-hidden="true">→</span>
            </a>
            {externalProjectLinks(mainProject).map((link) => (
              <a
                class="button button-secondary"
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label} ↗
              </a>
            ))}
          </div>
        </div>
      </article>
    )
  }

  {
    sideProjects.length > 0 && (
      <div class="home-projects__secondary">
        {sideProjects.map((project) => (
          <article class="card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
              <span class="tag">{project.category}</span>
              <span class="tag tag-accent">{project.status}</span>
            </div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div style="margin-top:auto; padding-top:16px; display:flex; gap:8px;">
              <a
                class="button button-secondary"
                style="flex:1;"
                href={`/projects/${project.slug}/`}
              >
                查看详情 →
              </a>
              {project.githubUrl && (
                <a
                  class="button button-secondary"
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener"
                  aria-label="GitHub"
                >
                  GH
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )
  }
</section>
