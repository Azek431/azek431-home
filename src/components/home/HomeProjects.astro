---
type ProjectHighlight = {
  label: string;
  value: string;
};

type ProjectItem = {
  slug: string;
  title: string;
  description: string;
  longDescription: string;
  category: string;
  status: string;
  accent: string;
  tags: string[];
  highlights: ProjectHighlight[];
  websiteUrl?: string;
  githubUrl?: string;
  giteeUrl?: string;
};

type ProjectPreview = {
  eyebrow: string;
  title: string;
  description: string;
  navigation: {
    label: string;
    count: string;
    active?: boolean;
  }[];
  records: {
    title: string;
    type: string;
    status: string;
  }[];
};

type Props = {
  mainProject?: ProjectItem;
  sideProjects: ProjectItem[];
  preview: ProjectPreview;
};

const { mainProject, sideProjects, preview } = Astro.props as Props;

function externalProjectLinks(project: ProjectItem) {
  return [
    project.websiteUrl && {
      label: '访问项目',
      href: project.websiteUrl,
    },
    project.githubUrl && {
      label: 'GitHub',
      href: project.githubUrl,
    },
    project.giteeUrl && {
      label: 'Gitee',
      href: project.giteeUrl,
    },
  ].filter(Boolean) as {
    label: string;
    href: string;
  }[];
}
---

<section id="featured-work" class="home-v5-projects" aria-labelledby="home-projects-title">
  <header class="home-v5-section-head">
    <div>
      <p>FEATURED WORK</p>
      <h2 id="home-projects-title">不只展示技术栈，更展示正在生长的作品。</h2>
    </div>

    <a href="/projects/">
      查看全部项目
      <span aria-hidden="true">→</span>
    </a>
  </header>

  {
    mainProject && (
      <article class="home-v5-project-feature" style={`--project-accent: ${mainProject.accent};`}>
        <div class="home-v5-project-feature__preview">
          <div class="home-v5-workspace" aria-label={`${mainProject.title} 项目预览`}>
            <header class="home-v5-workspace__bar">
              <div aria-hidden="true">
                <span />
                <span />
                <span />
              </div>

              <span>{mainProject.websiteUrl ?? mainProject.slug}</span>

              <b>LIVE</b>
            </header>

            <div class="home-v5-workspace__layout">
              <aside class="home-v5-workspace__sidebar">
                <div class="home-v5-workspace__brand">
                  <span>AZ</span>

                  <div>
                    <strong>资料库</strong>
                    <small>Knowledge base</small>
                  </div>
                </div>

                <nav aria-label="资料库预览目录">
                  {preview.navigation.map((item) => (
                    <span class:list={{ 'is-active': item.active }}>
                      <i aria-hidden="true" />
                      <strong>{item.label}</strong>
                      <small>{item.count}</small>
                    </span>
                  ))}
                </nav>

                <div class="home-v5-workspace__sync">
                  <i aria-hidden="true" />
                  GitHub / Gitee 已同步
                </div>
              </aside>

              <main class="home-v5-workspace__content">
                <div class="home-v5-workspace__heading">
                  <div>
                    <small>{preview.eyebrow}</small>
                    <strong>{preview.title}</strong>
                  </div>

                  <span>{mainProject.status}</span>
                </div>

                <p>{preview.description}</p>

                <div class="home-v5-workspace__summary">
                  {mainProject.highlights.slice(0, 3).map((highlight) => (
                    <span>
                      <small>{highlight.label}</small>
                      <strong>{highlight.value}</strong>
                    </span>
                  ))}
                </div>

                <div class="home-v5-workspace__records">
                  <header>
                    <span>最近整理的内容</span>
                    <small>{preview.records.length} records</small>
                  </header>

                  {preview.records.map((record, index) => (
                    <div>
                      <span>0{index + 1}</span>

                      <div>
                        <strong>{record.title}</strong>
                        <small>{record.type}</small>
                      </div>

                      <b>{record.status}</b>
                    </div>
                  ))}
                </div>
              </main>
            </div>
          </div>

          <span class="home-v5-project-feature__glow" aria-hidden="true" />
        </div>

        <div class="home-v5-project-feature__content">
          <div class="home-v5-project-feature__meta">
            <span>{mainProject.category}</span>
            <span>{mainProject.status}</span>
          </div>

          <h3>{mainProject.title}</h3>

          <p>{mainProject.longDescription || mainProject.description}</p>

          <dl class="home-v5-project-feature__stats">
            {mainProject.highlights.slice(0, 3).map((highlight) => (
              <div>
                <dt>{highlight.label}</dt>
                <dd>{highlight.value}</dd>
              </div>
            ))}
          </dl>

          <ul class="home-v5-project-feature__tags" aria-label="项目技术标签">
            {mainProject.tags.slice(0, 4).map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>

          <div class="home-v5-project-feature__actions">
            <a
              class="home-v5-button home-v5-button--primary"
              href={`/projects/${mainProject.slug}/`}
            >
              项目详情
              <span aria-hidden="true">→</span>
            </a>

            {externalProjectLinks(mainProject).map((link) => (
              <a
                class="home-v5-project-feature__external"
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.label}
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </div>
      </article>
    )
  }

  <div class="home-v5-projects__secondary">
    {
      sideProjects.map((project, index) => (
        <article class="home-v5-project-card" style={`--project-accent: ${project.accent};`}>
          <div class="home-v5-project-card__top">
            <span>0{index + 2}</span>

            <div>
              <small>{project.category}</small>
              <strong>{project.status}</strong>
            </div>
          </div>

          <div class="home-v5-project-card__body">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>

          <ul class="home-v5-project-card__tags" aria-label="项目标签">
            {project.tags.slice(0, 3).map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>

          <div class="home-v5-project-card__footer">
            <a href={`/projects/${project.slug}/`}>
              查看详情
              <span aria-hidden="true">→</span>
            </a>

            <div>
              {project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.title} GitHub 仓库`}
                >
                  GH
                </a>
              )}

              {project.giteeUrl && (
                <a
                  href={project.giteeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.title} Gitee 镜像`}
                >
                  GE
                </a>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
