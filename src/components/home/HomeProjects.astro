---
type ProjectItem = {
  slug: string;
  title: string;
  description: string;
  category: string;
  status: string;
  accent: string;
  tags: string[];
  websiteUrl?: string;
  githubUrl?: string;
  giteeUrl?: string;
};

type Props = {
  mainProject?: ProjectItem;
  sideProjects: ProjectItem[];
};

const { mainProject, sideProjects } = Astro.props as Props;

function externalProjectLinks(project: ProjectItem) {
  return [
    project.websiteUrl && {
      label: 'Website',
      href: project.websiteUrl,
      primary: true,
    },
    project.githubUrl && {
      label: 'GitHub',
      href: project.githubUrl,
    },
    project.giteeUrl && {
      label: 'Gitee 镜像',
      href: project.giteeUrl,
    },
  ].filter(Boolean) as { label: string; href: string; primary?: boolean }[];
}
---

<section class="section-v2 home-v3-projects" aria-labelledby="home-projects-title">
  <div class="section-head-v2">
    <p>Featured Projects</p>
    <h2 id="home-projects-title">项目精选</h2>
    <span>先展示最重要的作品，再展开 GitHub、Gitee 镜像和更多项目实验。</span>
  </div>

  <div class="home-v3-project-layout">
    {
      mainProject && (
        <article class="home-v3-project-main" style={`--project-accent: ${mainProject.accent}`}>
          <div>
            <p>{mainProject.category}</p>
            <strong>{mainProject.status}</strong>
          </div>

          <h3>{mainProject.title}</h3>
          <p>{mainProject.description}</p>

          <ul>
            {mainProject.tags.slice(0, 4).map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>

          <div class="home-v3-project-actions">
            <a
              class="ui-button ui-button-primary"
              href={`/projects/${mainProject.slug}/`}
              aria-label={`查看 ${mainProject.title} 项目详情`}
            >
              查看主项目
            </a>

            {externalProjectLinks(mainProject).map((link) => (
              <a
                class={
                  link.primary
                    ? 'project-mirror-link project-mirror-link--primary'
                    : 'project-mirror-link'
                }
                href={link.href}
                target="_blank"
                rel="noreferrer"
                aria-label={`在新窗口打开 ${mainProject.title} 的 ${link.label}`}
              >
                {link.label}
              </a>
            ))}
          </div>
        </article>
      )
    }

    <div class="home-v3-project-side">
      {
        sideProjects.map((project) => (
          <article style={`--project-accent: ${project.accent}`}>
            <div>
              <span>{project.category}</span>
              <strong>{project.status}</strong>
            </div>

            <h3>{project.title}</h3>
            <p>{project.description}</p>

            <div class="home-v3-project-side-actions">
              <a href={`/projects/${project.slug}/`} aria-label={`查看 ${project.title} 项目详情`}>
                查看详情 →
              </a>

              <span class="home-v3-project-mirrors" aria-label={`${project.title} 镜像入口`}>
                {externalProjectLinks(project)
                  .filter((link) => link.label !== 'Website')
                  .map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noreferrer"
                      aria-label={`在新窗口打开 ${project.title} 的 ${link.label}`}
                    >
                      {link.label}
                    </a>
                  ))}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
