---
import { relativeDate } from '../../data/time';

type UpdateItem = {
  title: string;
  desc: string;
  href: string;
  date: string;
};

type NetworkLink = {
  name: string;
  category: string;
  href: string;
  description?: string;
};

type Props = {
  updates: UpdateItem[];
  networkLinks: NetworkLink[];
};

const { updates, networkLinks } = Astro.props as Props;

const isExternal = (href: string) => href.startsWith('http');
---

<section class="home-v5-activity" aria-label="最近动态与公开身份">
  <div class="home-v5-activity__timeline">
    <header class="home-v5-section-head home-v5-section-head--compact">
      <div>
        <p>LATEST</p>
        <h2>最近发生的事情</h2>
      </div>

      <a href="/changelog/">
        完整记录
        <span aria-hidden="true">→</span>
      </a>
    </header>

    <div class="home-v5-timeline">
      {
        updates.map((update, index) => (
          <a
            class="home-v5-timeline__item"
            href={update.href}
            target={isExternal(update.href) ? '_blank' : undefined}
            rel={isExternal(update.href) ? 'noopener noreferrer' : undefined}
          >
            <span class="home-v5-timeline__marker" aria-hidden="true">
              <i />
            </span>

            <time datetime={update.date}>
              {update.date}
              <small>{relativeDate(update.date)}</small>
            </time>

            <div>
              <strong>{update.title}</strong>
              <p>{update.desc}</p>
            </div>

            <span class="home-v5-timeline__arrow" aria-hidden="true">
              {index === 0 ? '↗' : '→'}
            </span>
          </a>
        ))
      }
    </div>
  </div>

  <aside class="home-v5-identity" aria-labelledby="home-identity-title">
    <header>
      <p>PUBLIC IDENTITY</p>
      <h2 id="home-identity-title">在公开网络上找到我</h2>
      <span> GitHub 是主要代码来源，Gitee 提供同步镜像与另一条访问路径。 </span>
    </header>

    <div class="home-v5-identity__links">
      {
        networkLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer">
            <span>{link.name.slice(0, 2).toUpperCase()}</span>

            <div>
              <strong>{link.name}</strong>
              <small>{link.category}</small>
            </div>

            <i aria-hidden="true">↗</i>
          </a>
        ))
      }
    </div>

    <a class="home-v5-identity__more" href="/links/">
      查看全部公开入口
      <span aria-hidden="true">→</span>
    </a>
  </aside>
</section>
