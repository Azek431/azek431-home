---
import { relativeDate } from '../../data/time';

type UpdateItem = {
  title: string;
  desc: string;
  href: string;
  date: string;
};

type NetworkLink = {
  name: string;
  category: string;
  href: string;
  description?: string;
};

type Props = {
  updates: UpdateItem[];
  networkLinks: NetworkLink[];
};

const { updates, networkLinks } = Astro.props as Props;

const isExternal = (href: string) => href.startsWith('http');

function networkCode(name: string) {
  if (name === 'GitHub') return 'GH';
  if (name === 'Gitee') return 'GE';
  return name.slice(0, 2).toUpperCase();
}
---

<section class="home-activity" aria-label="最近动态与公开身份">
  <div class="home-activity__timeline">
    <div class="home-section-head home-section-head--compact">
      <div>
        <p>LATEST</p>
        <h2>最近发生的事情</h2>
      </div>
      <a href="/changelog/">完整记录 →</a>
    </div>

    <div class="home-activity__timeline">
      {
        updates.map((update, index) => (
          <a
            class="home-activity__timeline-item"
            href={update.href}
            target={isExternal(update.href) ? '_blank' : undefined}
            rel={isExternal(update.href) ? 'noopener noreferrer' : undefined}
            aria-label={`${update.title}，${update.date}`}
          >
            <span class="home-activity__timeline-marker" aria-hidden="true"></span>
            <div>
              <time class="home-activity__timeline-time" datetime={update.date}>
                {update.date}
                <small> · {relativeDate(update.date)}</small>
              </time>
              <div class="home-activity__timeline-title">{update.title}</div>
              <p class="home-activity__timeline-desc">{update.desc}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <aside class="home-activity__identity" aria-labelledby="home-identity-title">
    <h3 id="home-identity-title">Public Identity</h3>
    <p style="font-size:var(--text-sm); color:var(--color-text-muted); margin-bottom:var(--space-4); line-height:1.6;">
      GitHub 是主要代码来源，Gitee 提供同步镜像。
    </p>

    <div class="home-activity__identity-links">
      {
        networkLinks.map((link) => (
          <a
            class="home-activity__identity-link"
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`打开 Azek431 的 ${link.name}`}
          >
            <span>{networkCode(link.name)}</span>
            <div>
              <strong>{link.name}</strong>
              <small>{link.category}</small>
            </div>
          </a>
        ))
      }
    </div>

    <a class="button button-secondary" href="/links/" style="margin-top:var(--space-4); width:100%; justify-content:center;">
      查看全部公开入口 →
    </a>
  </aside>
</section>
