---
type NexusProject = {
  slug: string;
  title: string;
  category: string;
  status: string;
  accent: string;
};

type Props = {
  projects: readonly NexusProject[];
  projectCount: number;
};

const { projects, projectCount } = Astro.props as Props;

function projectHref(slug: string) {
  return `/projects/${slug}/`;
}
---

<aside
  class="home-v5-nexus"
  aria-label="Azek431 Digital Nexus 项目地图"
  data-nexus-map
  data-active="false"
>
  <header class="home-v5-nexus__header">
    <div>
      <span>LIVE MAP</span>
      <strong>Digital Nexus</strong>
    </div>

    <p>
      <i aria-hidden="true"></i>
      System online
    </p>
  </header>

  <div class="home-v5-nexus__stage">
    <span class="home-v5-nexus__orbit home-v5-nexus__orbit--outer" aria-hidden="true"> </span>
    <span class="home-v5-nexus__orbit home-v5-nexus__orbit--inner" aria-hidden="true"> </span>

    <span class="home-v5-nexus__beam home-v5-nexus__beam--one" aria-hidden="true"> </span>
    <span class="home-v5-nexus__beam home-v5-nexus__beam--two" aria-hidden="true"> </span>
    <span class="home-v5-nexus__beam home-v5-nexus__beam--three" aria-hidden="true"> </span>

    <a class="home-v5-nexus__core" href="/about/" aria-label="了解 Azek431">
      <span>AZ</span>
      <strong>Azek431</strong>
      <small>Creator node</small>
    </a>

    <div class="home-v5-nexus__nodes">
      {
        projects.map((project, index) => (
          <a
            class={`home-v5-nexus__node home-v5-nexus__node--${index + 1}`}
            href={projectHref(project.slug)}
            style={`--node-accent: ${project.accent};`}
            data-status={project.status}
          >
            <span>0{index + 1}</span>

            <div>
              <strong>{project.title}</strong>
              <small>{project.category}</small>
            </div>

            <b>{project.status}</b>
          </a>
        ))
      }
    </div>

    <span class="home-v5-nexus__pulse home-v5-nexus__pulse--one" aria-hidden="true"> </span>
    <span class="home-v5-nexus__pulse home-v5-nexus__pulse--two" aria-hidden="true"> </span>
  </div>

  <footer class="home-v5-nexus__footer">
    <span>
      <strong>{projectCount}</strong>
      connected project spaces
    </span>

    <a href="/now/">
      查看当前状态
      <span aria-hidden="true">→</span>
    </a>
  </footer>
</aside>

<script>
  const nexusMaps = document.querySelectorAll<HTMLElement>('[data-nexus-map]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reducedMotion || !('IntersectionObserver' in window)) {
    nexusMaps.forEach((map) => {
      map.dataset.active = reducedMotion ? 'false' : 'true';
    });
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const map = entry.target as HTMLElement;
          map.dataset.active = entry.isIntersecting ? 'true' : 'false';
        });
      },
      {
        rootMargin: '120px 0px',
        threshold: 0.08,
      },
    );

    nexusMaps.forEach((map) => observer.observe(map));
  }
</script>
