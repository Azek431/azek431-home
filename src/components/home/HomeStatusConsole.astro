---
type Props = {
  siteUpdatedRelative: string;
  liveProjects: number;
  plannedProjects: number;
  externalLinks: number;
};

const { siteUpdatedRelative, liveProjects, plannedProjects, externalLinks } = Astro.props as Props;
---

<aside class="home-v3-console" aria-label="站点运行状态">
  <div class="home-v3-console-head">
    <span>site.status</span>
    <strong>Running</strong>
  </div>

  <ul class="home-v3-console-strip" aria-label="核心指标">
    <li><strong>{liveProjects}</strong><span>已上线</span></li>
    <li><strong>{plannedProjects}</strong><span>计划中</span></li>
    <li><strong>{externalLinks}</strong><span>公开入口</span></li>
    <li><strong>{siteUpdatedRelative}</strong><span>最近更新</span></li>
  </ul>
</aside>
