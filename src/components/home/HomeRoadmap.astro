---
type Focus = {
  num?: string;
  step?: string;
  title: string;
  desc: string;
  status?: string;
  tone?: 'active' | 'complete' | 'planned';
};

type Props = {
  focuses: readonly Focus[];
};

const { focuses } = Astro.props as Props;
---

<section class="home-v5-now" aria-labelledby="home-now-title">
  <header class="home-v5-section-head">
    <div>
      <p>NOW / LATEST / NEXT</p>
      <h2 id="home-now-title">不是静态介绍，而是持续更新的工作现场。</h2>
    </div>

    <a href="/now/">
      查看 Now 页面
      <span aria-hidden="true">→</span>
    </a>
  </header>

  <div class="home-v5-now__grid">
    {
      focuses.map((focus, index) => (
        <article data-tone={focus.tone ?? 'planned'}>
          <div class="home-v5-now__top">
            <span>{focus.num ?? focus.step ?? `0${index + 1}`}</span>
            {focus.status && <small>{focus.status}</small>}
          </div>

          <h3>{focus.title}</h3>
          <p>{focus.desc}</p>

          <span class="home-v5-now__line" aria-hidden="true" />
        </article>
      ))
    }
  </div>
</section>
