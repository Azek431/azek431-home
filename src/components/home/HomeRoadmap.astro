---
type Focus = {
  num: string;
  title: string;
  desc: string;
};

type Props = {
  focuses: Focus[];
};

const { focuses } = Astro.props as Props;
---

<section class="section-v2 home-v3-roadmap" aria-labelledby="home-roadmap-title">
  <div class="section-head-v2">
    <p>Focus</p>
    <h2 id="home-roadmap-title">长期关注的方向</h2>
    <span>主站之外，我也会持续投入在这些方向上。</span>
  </div>

  <div class="home-v3-roadmap-grid">
    {
      focuses.map((focus) => (
        <article>
          <span>{focus.num}</span>
          <h3>{focus.title}</h3>
          <p>{focus.desc}</p>
        </article>
      ))
    }
  </div>
</section>
