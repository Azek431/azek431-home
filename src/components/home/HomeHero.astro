---
import { projectDetails } from '../../data/projects';

type FocusItem = {
  title: string;
  desc: string;
};

type SiteConfig = {
  name: string;
  description?: string;
  github?: string;
  url?: string;
};

type Props = {
  todayDate: string;
  pageCount: number;
  siteConfig: SiteConfig;
  focusItems: FocusItem[];
};

const { todayDate, pageCount, siteConfig, focusItems } = Astro.props as Props;

const homeProject = projectDetails.find((project) => project.slug === 'azek431-home');
const sourceUrl = homeProject?.githubUrl ?? siteConfig.github;
const mirrorUrl = homeProject?.giteeUrl;
---

<section class="home-v3-hero home-hero-v4" aria-labelledby="home-title">
  <div class="home-v3-copy home-hero-v4__copy">
    <p class="home-v3-kicker home-hero-v4__kicker">
      <span aria-hidden="true"></span>
      Azek431 Home · Personal Digital Space
    </p>

    <h1 id="home-title" class="home-hero-v4__title">
      <span>Azek431</span>
      <em>Digital Nexus</em>
    </h1>

    <p class="home-v3-lead home-hero-v4__lead">
      一个用于整理项目、AI
      实验、学习记录和公开入口的个人数字空间。这里会持续沉淀我的网站、资料库、工具实验和长期维护记录。
    </p>

    <div class="home-v3-actions home-hero-v4__actions" aria-label="首页主要操作">
      <a class="ui-button ui-button-primary" href="/projects/">查看项目</a>

      <a
        class="ui-button ui-button-secondary"
        href={sourceUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="在新窗口打开本站源码仓库"
      >
        本站源码
      </a>

      {
        mirrorUrl && (
          <a
            class="ui-button ui-button-ghost"
            href={mirrorUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="在新窗口打开本站 Gitee 镜像"
          >
            Gitee 镜像
          </a>
        )
      }
    </div>

    <ul class="home-v3-focus home-hero-v4__focus" aria-label="当前关注方向">
      {
        focusItems.slice(0, 3).map((item) => (
          <li>
            <strong>{item.title}</strong>
            <span>{item.desc}</span>
          </li>
        ))
      }
    </ul>

    <p class="home-hero-v4__meta">
      <span>Updated {todayDate}</span>
      <span>{pageCount} pages</span>
      <span>Astro / Cloudflare</span>
    </p>
  </div>

  <slot />
</section>
