---
interface PageHeroMeta {
  label: string;
  value: string | number;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  meta?: PageHeroMeta[];
  align?: 'left' | 'center';
  tone?: 'default' | 'soft' | 'compact';
}

const {
  eyebrow,
  title,
  description,
  meta = [],
  align = 'left',
  tone = 'default',
} = Astro.props as Props;

const titleSlug = String(title)
  .trim()
  .replace(/[^a-zA-Z0-9\u4e00-\u9fa5]+/g, '-')
  .replace(/^-+|-+$/g, '')
  .toLowerCase();

const titleId = `page-title-${titleSlug || 'main'}`;

const classes = ['page-hero-v3', `page-hero-v3--${align}`, `page-hero-v3--${tone}`].join(' ');
---

<section class={classes} aria-labelledby={titleId}>
  <div class="page-hero-v3__content">
    {
      eyebrow && (
        <p class="page-hero-v3__eyebrow">
          <span aria-hidden="true" />
          {eyebrow}
        </p>
      )
    }

    <h1 id={titleId}>{title}</h1>

    {description && <p class="page-hero-v3__description">{description}</p>}

    <slot />
  </div>

  {
    meta.length > 0 && (
      <dl class="page-hero-v3__meta" aria-label={`${title} 页面概览`}>
        {meta.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    )
  }
</section>
