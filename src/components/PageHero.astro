---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="page-hero">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>

  {description && <p class="page-hero-text">{description}</p>}
</section>
