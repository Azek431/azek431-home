---
import { actionShortcutItems, navigationShortcutItems } from '../data/navigation';

const shortcutGroups = [
  {
    id: 'navigation',
    number: '01',
    title: '页面导航',
    description: '先按 g，再按对应字母即可跳转。',
    items: navigationShortcutItems,
  },
  {
    id: 'actions',
    number: '02',
    title: '全局操作',
    description: '未输入文字时可以直接使用。',
    items: actionShortcutItems,
  },
];
---

<div class="shortcut-system shortcut-system-v2" data-shortcut-system>
  <button
    class="shortcut-trigger shortcut-trigger-v2"
    type="button"
    aria-expanded="false"
    aria-controls="shortcut-panel"
    aria-label="打开快捷键面板"
    title="查看快捷键 (?)"
    data-shortcut-trigger
  >
    <span aria-hidden="true">?</span>
    <strong>快捷键</strong>
  </button>

  <div
    id="shortcut-panel"
    class="shortcut-panel shortcut-panel-v2"
    role="dialog"
    aria-modal="false"
    aria-labelledby="shortcut-panel-title"
    aria-describedby="shortcut-panel-description"
    aria-hidden="true"
    hidden
    data-shortcut-panel
  >
    <div class="shortcut-panel-v2__head">
      <div>
        <p>Keyboard</p>

        <h2 id="shortcut-panel-title">快捷键</h2>

        <span id="shortcut-panel-description"> 使用键盘快速浏览页面和执行常用操作。 </span>
      </div>

      <button
        class="shortcut-panel-v2__close"
        type="button"
        aria-label="关闭快捷键面板"
        data-shortcut-close
      >
        <span aria-hidden="true">×</span>
      </button>
    </div>

    <div class="shortcut-panel-v2__groups">
      {
        shortcutGroups.map((group) => (
          <section class="shortcut-panel-v2__group" aria-labelledby={`shortcut-group-${group.id}`}>
            <header>
              <span>{group.number}</span>

              <div>
                <h3 id={`shortcut-group-${group.id}`}>{group.title}</h3>

                <p>{group.description}</p>
              </div>
            </header>

            <ul class="shortcut-panel-v2__list">
              {group.items.map((shortcut) => (
                <li>
                  <span class="shortcut-panel-v2__keys">
                    {shortcut.keys.map((key) => (
                      <kbd>{key}</kbd>
                    ))}
                  </span>

                  <span>{shortcut.label}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var system = document.querySelector('[data-shortcut-system]');

    if (!system) return;

    if (system.getAttribute('data-shortcut-ready') === 'true') {
      return;
    }

    system.setAttribute('data-shortcut-ready', 'true');

    var trigger = system.querySelector('[data-shortcut-trigger]');

    var panel = system.querySelector('[data-shortcut-panel]');

    var closeButton = system.querySelector('[data-shortcut-close]');

    if (!trigger || !panel || !closeButton) {
      return;
    }

    var lastFocused = null;

    function isOpen() {
      return trigger.getAttribute('aria-expanded') === 'true';
    }

    function getFocusableElements() {
      return Array.prototype.slice.call(
        panel.querySelectorAll('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'),
      );
    }

    function openPanel() {
      if (isOpen()) return;

      document.dispatchEvent(
        new CustomEvent('site:overlay-open', {
          detail: {
            source: 'shortcut-panel',
          },
        }),
      );

      lastFocused = document.activeElement;

      panel.hidden = false;
      panel.setAttribute('aria-hidden', 'false');

      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', '关闭快捷键面板');

      document.documentElement.classList.add('has-shortcut-panel-open');

      closeButton.focus();
    }

    function closePanel(restoreFocus) {
      if (!isOpen()) return;

      panel.setAttribute('aria-hidden', 'true');
      panel.hidden = true;

      trigger.setAttribute('aria-expanded', 'false');
      trigger.setAttribute('aria-label', '打开快捷键面板');

      document.documentElement.classList.remove('has-shortcut-panel-open');

      if (restoreFocus !== false && lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    function togglePanel() {
      if (isOpen()) {
        closePanel(true);
      } else {
        openPanel();
      }
    }

    trigger.addEventListener('click', togglePanel);

    closeButton.addEventListener('click', function () {
      closePanel(true);
    });

    document.addEventListener('pointerdown', function (event) {
      if (!isOpen()) return;

      if (!system.contains(event.target)) {
        closePanel(false);
      }
    });

    document.addEventListener('site:overlay-open', function (event) {
      var detail = event.detail || {};

      if (detail.source !== 'shortcut-panel') {
        closePanel(false);
      }
    });

    document.addEventListener('site:overlay-close-all', function () {
      closePanel(false);
    });

    document.addEventListener('keydown', function (event) {
      if (!isOpen()) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        closePanel(true);
        return;
      }

      if (event.key !== 'Tab') return;

      var focusable = getFocusableElements();

      if (focusable.length === 0) return;

      var first = focusable[0];
      var last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    window.addEventListener('pagehide', function () {
      closePanel(false);
    });
  })();
</script>
