---
import RuntimeCounter from './RuntimeCounter.astro';
import ShortcutPanel from './ShortcutPanel.astro';
import { siteConfig } from '../data/site';
import { getSiteAge, siteStartedAtIso, siteStartedDateTime } from '../data/time';

const year = new Date().getFullYear();
const siteAge = getSiteAge();

const primaryLinks = [
  { label: '首页', href: '/' },
  { label: '项目', href: '/projects/' },
  { label: '链接', href: '/links/' },
  { label: '搜索', href: '/search/' },
];

const secondaryLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Now', href: '/now/' },
  { label: 'Stats', href: '/stats/' },
  { label: 'Changelog', href: '/changelog/' },
];

const publicLinks = [
  { label: 'GitHub', href: siteConfig.github },
  { label: 'RSS', href: '/rss.xml' },
  { label: 'Sitemap', href: '/sitemap.xml' },
];

const isExternal = (href: string) => href.startsWith('http');
---

<footer class="site-footer" aria-label="站点页脚">
  <div class="footer-shell footer-shell-v3">
    <section class="footer-brand-v3" aria-labelledby="footer-brand-title">
      <p>Azek431 Digital Nexus</p>
      <h2 id="footer-brand-title">{siteConfig.name}</h2>
      <span> 一个持续打磨的个人数字空间，用来连接项目、学习记录、AI 实验和公开入口。 </span>
    </section>

    <nav class="footer-nav-v3" aria-label="页脚主要导航">
      <div>
        <h3>Navigate</h3>
        {primaryLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>

      <div>
        <h3>System</h3>
        {secondaryLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>

      <div>
        <h3>Public</h3>
        {
          publicLinks.map((link) => (
            <a
              href={link.href}
              target={isExternal(link.href) ? '_blank' : undefined}
              rel={isExternal(link.href) ? 'noreferrer' : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </nav>

    <section class="footer-runtime-v3" aria-label="站点运行时间">
      <div>
        <span>Created</span>
        <strong>{siteStartedDateTime}</strong>
      </div>

      <div>
        <span>Running</span>
        <strong>
          <RuntimeCounter
            startedAt={siteStartedAtIso}
            fallback={siteAge.preciseLabel}
            className="footer-runtime-counter"
          />
        </strong>
      </div>
    </section>

    <div class="footer-bottom-v3">
      <p>© {year} {siteConfig.name}. Built with Astro & deployed on Cloudflare Pages.</p>
      <ShortcutPanel />
    </div>
  </div>
</footer>
