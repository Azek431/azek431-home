---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---
{items.length > 0 && (
  <nav class="breadcrumb" aria-label="面包屑">
    <ol>
      {items.map((it, i) => (
        <li>
          {it.href && i < items.length - 1 ? (
            <a href={it.href}>{it.label}</a>
          ) : (
            <span aria-current="page">{it.label}</span>
          )}
          {i < items.length - 1 && <span class="sep" aria-hidden="true">/</span>}
        </li>
      ))}
    </ol>
  </nav>
)}
