---
interface Props {
  title: string;
  description: string;
  href?: string;
  status?: string;
  category?: string;
  tags?: string[];
}

const { title, description, href = '#', status = '查看详情', category, tags = [] } = Astro.props;

const isPlaceholder = !href || href === '#';
const isExternal = href.startsWith('http://') || href.startsWith('https://');
const cardClass = isPlaceholder ? 'nav-card nav-card--disabled' : 'nav-card';
const linkLabel = isPlaceholder ? '即将开放' : status;
---

<a
  class={cardClass}
  href={isPlaceholder ? undefined : href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
  aria-disabled={isPlaceholder ? 'true' : undefined}
>
  <div class="nav-card__content">
    {category && <span class="nav-card__category">{category}</span>}

    <h3>{title}</h3>
    <p>{description}</p>

    {
      tags.length > 0 && (
        <div class="nav-card__tags" aria-label="相关标签">
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      )
    }
  </div>

  <span class="nav-card__status">{linkLabel}</span>
</a>
