---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projectDetails, type ProjectDetail } from '../data/projects';

const liveCount = projectDetails.filter((p) => p.status === '已上线').length;
const wipCount = projectDetails.filter(
  (p) => p.status === '维护中' || p.status === '计划中',
).length;
const ideaCount = projectDetails.filter((p) => p.status === '构想中').length;

const stats = [
  { label: '已上线', value: liveCount },
  { label: '进行中', value: wipCount },
  { label: '构想中', value: ideaCount },
  { label: '总项目', value: projectDetails.length },
];

function projectHref(project: ProjectDetail) {
  return `/projects/${project.slug}/`;
}
---

<BaseLayout
  title="项目展示台"
  description="整理 Azek431 的个人主站、项目官网、资料库、博客计划、AI 实验和更多技术实践。"
>
  <section class="section">
    <!-- Hero -->
    <div class="section-heading">
      <p class="eyebrow">Project Showcase</p>
      <h1>项目展示台</h1>
      <p>
        这里集中整理我的个人主站、文档站、博客计划、AI
        实验和后续技术实践。已上线项目会优先提供网站、GitHub 和 Gitee 镜像入口。
      </p>
    </div>

    <!-- Stats -->
    <div class="projects-summary">
      {
        stats.map((item) => (
          <div class="projects-summary__item">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))
      }
    </div>

    <!-- Project Grid -->
    <div class="card-grid">
      {
        projectDetails.map((project, index) => (
          <div class="card" style="position: relative; overflow: hidden;">
            {/* 卡片顶部 accent 色彩条 */}
            {project.accent && (
              <div
                style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: {project.accent}; opacity: 0.7;"
              />
            )}
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-3);">
              <span class="tag">{project.category}</span>
              <span class="tag tag-accent">{project.status}</span>
            </div>
            <p style="font-size: var(--text-xs); font-family: ui-monospace, monospace; color: var(--color-text-faint); margin-bottom: var(--space-1);">
              #{String(index + 1).padStart(2, '0')}
            </p>
            <h2 style="font-size: var(--text-xl); margin-bottom: var(--space-1);">
              {project.title}
            </h2>
            <p>{project.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-3);">
              {project.tags.slice(0, 6).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: var(--space-4);">
              <span style="font-size: var(--text-xs); color: var(--color-text-faint);">
                更新于 {project.lastUpdated}
              </span>
              <a
                class="button button-primary"
                href={projectHref(project)}
                style="min-height: 32px; padding: 0 var(--space-3); font-size: var(--text-xs);"
                aria-label={`查看 ${project.title} 项目详情`}
              >
                查看详情
              </a>
            </div>
            {(() => {
              const websiteUrl = project.websiteUrl;
              const githubUrl = project.githubUrl;
              const giteeUrl = project.giteeUrl;
              const hasLinks = websiteUrl || githubUrl || giteeUrl;
              if (!hasLinks) return null;
              return (
                <div style="display: flex; gap: var(--space-2); margin-top: var(--space-2); flex-wrap: wrap;">
                  {websiteUrl && (
                    <a
                      class="button button-secondary"
                      href={websiteUrl}
                      target="_blank"
                      rel="noreferrer"
                      style="min-height: 32px; padding: 0 var(--space-3); font-size: var(--text-xs);"
                    >
                      访问网站
                    </a>
                  )}
                  {githubUrl && (
                    <a
                      class="button button-secondary"
                      href={githubUrl}
                      target="_blank"
                      rel="noreferrer"
                      style="min-height: 32px; padding: 0 var(--space-3); font-size: var(--text-xs);"
                    >
                      GitHub
                    </a>
                  )}
                  {giteeUrl && (
                    <a
                      class="button button-secondary"
                      href={giteeUrl}
                      target="_blank"
                      rel="noreferrer"
                      style="min-height: 32px; padding: 0 var(--space-3); font-size: var(--text-xs);"
                    >
                      Gitee 镜像
                    </a>
                  )}
                </div>
              );
            })()}
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
