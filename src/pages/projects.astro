---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import NavCard from '../components/NavCard.astro';
import { projects } from '../data/site';
---

<BaseLayout title="Projects" description="Azek431 的项目展示与项目导航入口。">
  <PageHero
    eyebrow="Showcase"
    title="当前项目"
    text="这里会手动整理我的网站、仓库、博客计划、AI 实验和其他技术实践。"
  />

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Project Index</p>
      <h2>项目入口</h2>
      <p>
        一个项目只显示一张卡片。已上线项目会在卡片底部提供官网、GitHub 和 Gitee
        镜像入口；计划中的项目会先作为后续方向记录下来。
      </p>
    </div>

    <div class="cards">
      {
        projects.map((project) => (
          <NavCard
            title={project.name}
            description={project.description}
            href={project.href}
            status={project.status}
            category={project.category}
            tags={project.tags}
            links={project.links}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
