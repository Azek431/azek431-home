---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHero from '../components/PageHero.astro';
import { projectDetails, type ProjectDetail } from '../data/projects';

const liveCount = projectDetails.filter((p) => p.status === '已上线').length;
const wipCount = projectDetails.filter(
  (p) => p.status === '维护中' || p.status === '计划中',
).length;
const ideaCount = projectDetails.filter((p) => p.status === '构想中').length;

const stats = [
  { label: '已上线', value: liveCount },
  { label: '进行中', value: wipCount },
  { label: '构想中', value: ideaCount },
  { label: '总项目', value: projectDetails.length },
];

function projectHref(project: ProjectDetail) {
  return `/projects/${project.slug}/`;
}

function projectLinks(project: ProjectDetail) {
  return [
    project.websiteUrl && {
      label: '访问网站',
      href: project.websiteUrl,
      primary: true,
    },
    project.githubUrl && {
      label: 'GitHub',
      href: project.githubUrl,
    },
    project.giteeUrl && {
      label: 'Gitee 镜像',
      href: project.giteeUrl,
    },
  ].filter(Boolean) as { label: string; href: string; primary?: boolean }[];
}
---

<BaseLayout
  title="项目展示台"
  description="整理 Azek431 的个人主站、项目官网、资料库、博客计划、AI 实验和更多技术实践。"
>
  <main class="projects-v3">
    <Breadcrumb items={[{ label: '首页', href: '/' }, { label: '项目展示台' }]} />

    <PageHero
      eyebrow="Project Showcase"
      title="项目展示台"
      description="这里集中整理我的个人主站、文档站、博客计划、AI 实验和后续技术实践。已上线项目会优先提供网站、GitHub 和 Gitee 镜像入口。"
      meta={stats}
    />

    <section class="project-showcase-v3" aria-label="项目列表">
      {
        projectDetails.map((project, index) => {
          const links = projectLinks(project);

          return (
            <article class="project-card-v3" style={`--project-accent: ${project.accent}`}>
              <div class="project-card-v3__top">
                <span>{project.category}</span>
                <strong>{project.status}</strong>
              </div>

              <div class="project-card-v3__body">
                <p>#{String(index + 1).padStart(2, '0')}</p>
                <h2>{project.title}</h2>
                <span>{project.description}</span>
              </div>

              <ul class="project-card-v3__tags">
                {project.tags.slice(0, 6).map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>

              <div class="project-card-v3__meta">
                <span>更新于 {project.lastUpdated}</span>
              </div>

              <div class="project-card-v3__actions">
                <a
                  class="ui-button ui-button-primary"
                  href={projectHref(project)}
                  aria-label={`查看 ${project.title} 项目详情`}
                >
                  查看详情
                </a>

                {links.map((link) => (
                  <a
                    class={
                      link.primary
                        ? 'project-mirror-link project-mirror-link--primary'
                        : 'project-mirror-link'
                    }
                    href={link.href}
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`在新窗口打开 ${project.title} 的 ${link.label}`}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </article>
          );
        })
      }
    </section>
  </main>
</BaseLayout>
