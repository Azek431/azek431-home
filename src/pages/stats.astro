---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { changelog } from '../data/changelog';
import { projectDetails } from '../data/projects';
import { links, recentUpdates, sitePages } from '../data/site';
import {
  getSiteAge,
  siteStartedDateTime,
  siteStartedHash,
  siteUpdatedDateTime,
  siteUpdatedHash,
} from '../data/time';

const liveProjects = projectDetails.filter((p) => p.status === '已上线').length;
const planProjects = projectDetails.filter((p) => p.status !== '已上线').length;
const totalChanges = changelog.reduce((acc, item) => acc + item.changes.length, 0);
const totalTags = projectDetails.reduce((acc, item) => acc + (item.tags?.length || 0), 0);
const siteAge = getSiteAge();
const pageCount = sitePages.length + projectDetails.length + 1;

const overview = [
  { label: '站内页面', value: pageCount, suffix: ' 个', tone: 'blue' },
  { label: '项目记录', value: projectDetails.length, suffix: ' 个', tone: 'green' },
  { label: '公开链接', value: links.length, suffix: ' 个', tone: 'violet' },
  { label: '更新版本', value: changelog.length, suffix: ' 个', tone: 'amber' },
];

type StatMetric = {
  label: string;
  value: string | number;
  suffix?: string;
};

type StatGroup = {
  title: string;
  desc: string;
  metrics: StatMetric[];
};
const groups: StatGroup[] = [
  {
    title: '项目',
    desc: '项目数量、状态和内容结构。',
    metrics: [
      { label: '已上线', value: liveProjects, suffix: ' 个' },
      { label: '规划 / 实验', value: planProjects, suffix: ' 个' },
      { label: '项目标签', value: totalTags, suffix: ' 个' },
    ],
  },
  {
    title: '迭代',
    desc: '更新日志和版本变更记录。',
    metrics: [
      { label: '版本记录', value: changelog.length, suffix: ' 个' },
      { label: '总改动', value: totalChanges, suffix: ' 条' },
      { label: '最近更新', value: recentUpdates.length, suffix: ' 条' },
    ],
  },
  {
    title: '时间',
    desc: '建站时间和当前站点年龄。',
    metrics: [
      { label: '完整天数', value: siteAge.days, suffix: ' 天' },
      { label: '约合周数', value: siteAge.weeks, suffix: ' 周' },
      { label: '约合月份', value: siteAge.months, suffix: ' 个月' },
    ],
  },
  {
    title: '构建',
    desc: '构建时间和提交信息。',
    metrics: [
      { label: '首个提交', value: siteStartedHash },
      { label: '构建提交', value: siteUpdatedHash },
      { label: '订阅源', value: 'RSS' },
    ],
  },
];
---

<BaseLayout title="统计 · Azek431" description="Azek431 个人主站的项目、内容、时间和本地访问统计。">
  <Breadcrumb items={[{ label: '统计', href: '/stats/' }]} />

  <section class="page-v2-hero stats-hero-v2">
    <div>
      <p class="page-v2-kicker">Site Dashboard</p>
      <h1>主站数据</h1>
      <p>
        这里记录主站的页面、项目、链接、更新日志和构建信息。
        部分数据来自静态构建，部分访问数据只保存在当前浏览器。
      </p>
    </div>

    <div class="stats-build-card">
      <span>Started</span>
      <strong>{siteStartedDateTime}</strong>
      <span>Last build</span>
      <strong>{siteUpdatedDateTime}</strong>
    </div>
  </section>

  <section class="stats-overview-v2" aria-label="站点总览">
    {
      overview.map((item) => (
        <article data-tone={item.tone}>
          <strong>
            {item.value}
            {item.suffix}
          </strong>
          <span>{item.label}</span>
        </article>
      ))
    }
  </section>

  <section class="stats-grid-v2" aria-label="详细统计">
    {
      groups.map((group) => (
        <article>
          <div>
            <p>{group.title}</p>
            <h2>{group.desc}</h2>
          </div>

          <dl>
            {group.metrics.map((metric) => (
              <div>
                <dt>{metric.label}</dt>
                <dd>
                  {metric.value}
                  {metric.suffix ?? ''}
                </dd>
              </div>
            ))}
          </dl>
        </article>
      ))
    }
  </section>

  <section class="local-stats-v2" aria-label="本地访问统计">
    <div>
      <p>Local</p>
      <h2>本设备访问记录</h2>
      <span> 这部分由浏览器 localStorage 记录，只在你自己的设备上累计。 </span>
    </div>

    <div class="local-stats-grid-v2">
      <article>
        <strong data-session-count>—</strong>
        <span>本次会话访问</span>
      </article>
      <article>
        <strong data-total-count>—</strong>
        <span>累计访问</span>
      </article>
      <article>
        <strong data-first-visit>—</strong>
        <span>首次访问</span>
      </article>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var sessionEl = document.querySelector('[data-session-count]');
    var totalEl = document.querySelector('[data-total-count]');
    var firstEl = document.querySelector('[data-first-visit]');

    if (!sessionEl || !totalEl || !firstEl) return;

    var sessionKey = 'azek431-session-count';
    var totalKey = 'azek431-total-count';
    var firstKey = 'azek431-first-visit';

    var session = Number(sessionStorage.getItem(sessionKey) || '0') + 1;
    var total = Number(localStorage.getItem(totalKey) || '0') + 1;
    var first = localStorage.getItem(firstKey);

    if (!first) {
      first = new Date().toLocaleString('zh-CN');
      localStorage.setItem(firstKey, first);
    }

    sessionStorage.setItem(sessionKey, String(session));
    localStorage.setItem(totalKey, String(total));

    sessionEl.textContent = String(session);
    totalEl.textContent = String(total);
    firstEl.textContent = first;
  })();
</script>
