---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHero from '../components/PageHero.astro';
import RuntimeCounter from '../components/RuntimeCounter.astro';
import { changelog } from '../data/changelog';
import { projectDetails } from '../data/projects';
import { links, recentUpdates, sitePages } from '../data/site';
import {
  getSiteAge,
  siteStartedAtIso,
  siteStartedDateTime,
  siteStartedHash,
  siteUpdatedDateTime,
  siteUpdatedHash,
} from '../data/time';

type DashboardMetric = {
  label: string;
  value: string | number;
  suffix?: string;
};

type DashboardSection = {
  kicker: string;
  title: string;
  value: string | number;
  suffix?: string;
  desc: string;
  tone: 'blue' | 'violet' | 'green' | 'amber';
  metrics: DashboardMetric[];
};

const liveProjects = projectDetails.filter((project) => project.status === '已上线').length;
const plannedProjects = projectDetails.length - liveProjects;
const majorReleases = changelog.filter((entry) => entry.tone === 'major').length;
const totalChanges = changelog.reduce((acc, entry) => acc + entry.changes.length, 0);
const totalTags = projectDetails.reduce((acc, project) => acc + (project.tags?.length || 0), 0);
const totalFeatures = projectDetails.reduce(
  (acc, project) => acc + (project.features?.length || 0),
  0,
);
const pageCount = sitePages.length + projectDetails.length + 1;
const siteAge = getSiteAge();

const publicLinks = links.filter((link) => link.href.startsWith('http')).length;
const siteLinks = links.length - publicLinks;

const dashboardSections: DashboardSection[] = [
  {
    kicker: 'Project',
    title: '项目系统',
    value: projectDetails.length,
    suffix: '个',
    desc: '主站目前整理的项目、官网、资料库和实验方向。',
    tone: 'blue',
    metrics: [
      { label: '已上线', value: liveProjects, suffix: '个' },
      { label: '规划 / 实验', value: plannedProjects, suffix: '个' },
      { label: '标签', value: totalTags, suffix: '个' },
      { label: '特性条目', value: totalFeatures, suffix: '条' },
    ],
  },
  {
    kicker: 'Iteration',
    title: '迭代记录',
    value: changelog.length,
    suffix: '次',
    desc: '记录主站每一轮结构、视觉、内容和工程细节优化。',
    tone: 'violet',
    metrics: [
      { label: '大版本', value: majorReleases, suffix: '次' },
      { label: '总改动', value: totalChanges, suffix: '条' },
      { label: '最近更新', value: recentUpdates.length, suffix: '条' },
      { label: '构建提交', value: siteUpdatedHash },
    ],
  },
  {
    kicker: 'Time',
    title: '运行时间',
    value: siteAge.days,
    suffix: '天',
    desc: '统一使用建站时间作为运行起点，Footer 和 Stats 保持同一口径。',
    tone: 'green',
    metrics: [
      { label: '建站于', value: siteStartedDateTime },
      { label: '完整周数', value: siteAge.weeks, suffix: '周' },
      { label: '约合月份', value: siteAge.months, suffix: '个月' },
      { label: '首个提交', value: siteStartedHash },
    ],
  },
  {
    kicker: 'Content',
    title: '内容入口',
    value: pageCount,
    suffix: '页',
    desc: '页面、链接、订阅源和站点地图共同构成公开访问入口。',
    tone: 'amber',
    metrics: [
      { label: '公开链接', value: publicLinks, suffix: '个' },
      { label: '站内入口', value: siteLinks, suffix: '个' },
      { label: 'RSS', value: 'Ready' },
      { label: 'Sitemap', value: 'XML' },
    ],
  },
];
---

<BaseLayout
  title="主站数据"
  description="查看 Azek431 主站的项目、迭代、运行时间、内容入口和本地访问统计。"
>
  <main class="stats-v3">
    <Breadcrumb items={[{ label: '首页', href: '/' }, { label: '主站数据' }]} />

    <PageHero
      eyebrow="Stats Dashboard"
      title="主站数据"
      description="把项目、迭代、运行时间和内容入口整理成一组更清晰的第一代玻璃仪表盘。"
      meta={[
        { label: '页面', value: pageCount },
        { label: '项目', value: projectDetails.length },
        { label: '更新', value: changelog.length },
        { label: '公开链接', value: publicLinks },
      ]}
    />

    <section class="stats-dashboard-v3" aria-label="主站数据仪表盘">
      {
        dashboardSections.map((section) => (
          <article data-tone={section.tone}>
            <div class="stats-dashboard-v3__head">
              <p>{section.kicker}</p>
              <h2>{section.title}</h2>
              <span>{section.desc}</span>
            </div>

            <strong class="stats-dashboard-v3__value">
              {section.value}
              {section.suffix && <small>{section.suffix}</small>}
            </strong>

            <dl class="stats-dashboard-v3__metrics">
              {section.metrics.map((metric) => (
                <div>
                  <dt>{metric.label}</dt>
                  <dd>
                    {metric.value}
                    {metric.suffix && <small>{metric.suffix}</small>}
                  </dd>
                </div>
              ))}
            </dl>
          </article>
        ))
      }
    </section>

    <section class="stats-runtime-v3" aria-labelledby="stats-runtime-title">
      <div>
        <p>Live Runtime</p>
        <h2 id="stats-runtime-title">实时运行中</h2>
        <span>这部分由浏览器实时计算，和 Footer 使用同一个建站时间。</span>
      </div>

      <strong>
        <RuntimeCounter startedAt={siteStartedAtIso} fallback={siteAge.preciseLabel} />
      </strong>

      <small>最近构建时间：{siteUpdatedDateTime}</small>
    </section>

    <section class="local-stats-v3" aria-labelledby="local-stats-title">
      <div>
        <p>Local</p>
        <h2 id="local-stats-title">本地访问统计</h2>
        <span>这些数据只保存在你的浏览器 localStorage 中，不会上传。</span>
      </div>

      <dl>
        <div>
          <dt>本次会话</dt>
          <dd data-local-stat="session">—</dd>
        </div>
        <div>
          <dt>累计访问</dt>
          <dd data-local-stat="total">—</dd>
        </div>
        <div>
          <dt>首次访问</dt>
          <dd data-local-stat="first">—</dd>
        </div>
      </dl>
    </section>
  </main>

  <script is:inline>
    (function () {
      var session = Number(sessionStorage.getItem('azek-session-views') || '0') + 1;
      var total = Number(localStorage.getItem('azek-total-views') || '0') + 1;
      var first = localStorage.getItem('azek-first-visit');

      if (!first) {
        first = new Date().toLocaleDateString('zh-CN');
        localStorage.setItem('azek-first-visit', first);
      }

      sessionStorage.setItem('azek-session-views', String(session));
      localStorage.setItem('azek-total-views', String(total));

      var sessionNode = document.querySelector('[data-local-stat="session"]');
      var totalNode = document.querySelector('[data-local-stat="total"]');
      var firstNode = document.querySelector('[data-local-stat="first"]');

      if (sessionNode) sessionNode.textContent = session + ' 次';
      if (totalNode) totalNode.textContent = total + ' 次';
      if (firstNode) firstNode.textContent = first;
    })();
  </script>
</BaseLayout>
