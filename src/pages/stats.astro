---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { changelog } from '../data/changelog';
import { projectDetails } from '../data/projects';
import { links, navItems, recentUpdates } from '../data/site';

const liveProjects = projectDetails.filter((p) => p.status === '已上线').length;
const planProjects = projectDetails.filter((p) => p.status !== '已上线').length;
const majorReleases = changelog.filter((e) => e.tone === 'major').length;
const minorReleases = changelog.filter((e) => e.tone === 'minor').length;
const patchReleases = changelog.filter((e) => e.tone === 'patch').length;
const totalChanges = changelog.reduce((acc, e) => acc + e.changes.length, 0);
const totalTags = projectDetails.reduce((acc, p) => acc + (p.tags?.length || 0), 0);
const totalFeatures = projectDetails.reduce((acc, p) => acc + (p.features?.length || 0), 0);

const startDate = new Date('2025-10-12T00:00:00Z');
const now = new Date();
const daysRunning = Math.floor((now.getTime() - startDate.getTime()) / 86400000);
const weeksRunning = Math.floor(daysRunning / 7);
const monthsRunning = (now.getFullYear() - startDate.getFullYear()) * 12 + (now.getMonth() - startDate.getMonth());
const pageCount = navItems.length + projectDetails.length + 1;

const sections = [
  {
    title: '项目',
    metrics: [
      { label: '总项目数',   value: projectDetails.length, suffix: '个',     tone: 'primary' },
      { label: '已上线',     value: liveProjects,           suffix: '个',     tone: 'success' },
      { label: '规划 / 实验', value: planProjects,           suffix: '个',     tone: 'accent'  },
      { label: '总标签数',   value: totalTags,              suffix: '个',     tone: 'primary' },
      { label: '特性条目',   value: totalFeatures,          suffix: '条',     tone: 'primary' },
    ],
  },
  {
    title: '迭代',
    metrics: [
      { label: '总版本',     value: changelog.length,       suffix: '个',     tone: 'primary' },
      { label: '大版本',     value: majorReleases,          suffix: '次',     tone: 'success' },
      { label: '小版本',     value: minorReleases,          suffix: '次',     tone: 'accent'  },
      { label: '补丁',       value: patchReleases,          suffix: '次',     tone: 'muted'   },
      { label: '总改动',     value: totalChanges,           suffix: '条',     tone: 'primary' },
    ],
  },
  {
    title: '时间',
    metrics: [
      { label: '建站于',     value: '2025.10.12',           tone: 'muted'   },
      { label: '已运行',     value: daysRunning,            suffix: ' 天',    tone: 'primary' },
      { label: '约合',       value: weeksRunning,           suffix: ' 周',    tone: 'accent'  },
      { label: '约合',       value: monthsRunning,          suffix: ' 个月',  tone: 'success' },
      { label: '下次更新',   value: '随时',                 tone: 'muted'   },
    ],
  },
  {
    title: '内容',
    metrics: [
      { label: '最近更新条目', value: recentUpdates.length, suffix: ' 条',  tone: 'primary' },
      { label: '公开链接',     value: links.length,         suffix: ' 个',  tone: 'accent'  },
      { label: '站内页面',     value: pageCount,             suffix: ' 个',  tone: 'success' },
      { label: '订阅源',       value: 'RSS',                tone: 'muted'   },
      { label: '站点地图',     value: 'XML',                tone: 'muted'   },
    ],
  },
];

const toneColor: Record<string, string> = {
  primary: '#a8c8ff',
  success: '#6ee7b7',
  accent:  '#c4b5fd',
  muted:   '#c4cee0',
};
---
<BaseLayout
  title="Stats - Azek431"
  description="主站的简单数据和指标。"
>
  <Breadcrumb items={[{ label: '首页', href: '/' }, { label: 'Stats' }]} />

  <PageHero
    eyebrow="Stats"
    title="主站数据"
    description="这一页用最简单的数字展示主站的「形状」——项目、迭代、时间、内容四个维度。数字不一定代表什么,只是为了「在维护」这件事有可触摸的痕迹。"
    meta={[
      { label: '项目', value: projectDetails.length + ' 个' },
      { label: '迭代', value: changelog.length + ' 版' },
      { label: '链接', value: links.length + ' 条' },
      { label: '最近', value: '2026-06-04' },
    ]}
  />

  {sections.map((s) => (
    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">{s.title}</p>
        <h2>{s.title}</h2>
      </div>
      <div class="stats-grid">
        {s.metrics.map((m) => (
          <div class="stat-card" style={'--stat-accent:' + (toneColor[m.tone || 'primary']) + ';'}>
            <span class="stat-value">{m.value}{m.suffix || ''}</span>
            <span class="stat-label">{m.label}</span>
          </div>
        ))}
      </div>
    </section>
  ))}

  <section class="section">
    <div class="now-cta">
      <h3>数字会变,主站会继续</h3>
      <p>所有数据在 build 时计算,不会实时更新;真正的"运行中"状态以最近一次 commit 为准。</p>
      <div class="actions">
        <a class="button primary" href="/changelog/">看更新日志</a>
        <a class="button secondary" href="/rss.xml" target="_blank" rel="noreferrer noopener">订阅 RSS</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Live</p>
      <h2>实时</h2>
      <p>这部分数据由浏览器 localStorage 记录,只在你自己的设备上累计。</p>
    </div>
    <div class="stats-grid">
      <div class="stat-card" style="--stat-accent: #6ee7b7;" data-visit-card>
        <span class="stat-value" data-visit-count>—</span>
        <span class="stat-label">本次会话访问</span>
      </div>
      <div class="stat-card" style="--stat-accent: #a8c8ff;" data-session-card>
        <span class="stat-value" data-session-count>—</span>
        <span class="stat-label">累计访问</span>
      </div>
      <div class="stat-card" style="--stat-accent: #c4b5fd;" data-first-card>
        <span class="stat-value" data-first-date>—</span>
        <span class="stat-label">首次访问</span>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function () {
    var key = 'azek431-visit';
    var today = new Date().toISOString().slice(0, 10);
    var data;
    try {
      data = JSON.parse(localStorage.getItem(key) || '{}');
    } catch (e) { data = {}; }
    if (data.date !== today) {
      data.date = today;
      data.todayCount = 1;
    } else {
      data.todayCount = (data.todayCount || 0) + 1;
    }
    data.totalCount = (data.totalCount || 0) + 1;
    if (!data.firstDate) data.firstDate = today;
    try { localStorage.setItem(key, JSON.stringify(data)); } catch (e) {}

    function set(sel, val) {
      var el = document.querySelector(sel);
      if (el) el.textContent = val;
    }
    set('[data-visit-count]', String(data.todayCount));
    set('[data-session-count]', String(data.totalCount));
    set('[data-first-date]', data.firstDate);
  })();
</script>
