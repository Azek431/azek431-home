---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const plans = [
  {
    num: 1,
    tag: '写作基础',
    title: 'Markdown 工作流 + Git 版本管理',
    desc: '用 Markdown 写正文,Git 仓库管理多版本草稿,支持本地预览与一键发布。',
    state: 'in-progress',
  },
  {
    num: 2,
    tag: '内容检索',
    title: '标签体系 + 全站搜索',
    desc: '统一标签分类,接入现有 search 索引,实现跨文章、跨项目的全文检索。',
    state: 'planning',
  },
  {
    num: 3,
    tag: '订阅分发',
    title: 'RSS 全文输出 + OG 卡片',
    desc: '为每篇文章生成独立 RSS 源和 OG 分享卡,提高订阅和社媒传播效果。',
    state: 'planning',
  },
  {
    num: 4,
    tag: '阅读体验',
    title: 'Shiki 代码高亮 + 主题切换',
    desc: '统一代码块主题,支持亮 / 暗双主题切换,锚点导航 + 阅读进度条。',
    state: 'planning',
  },
];

const drafts = [
  {
    title: '建站一年记',
    desc: '回顾从零搭站到现在的迭代节点、技术选型、心路历程。',
    tag: '随笔',
    est: '2026-07',
  },
  {
    title: 'Azek431 设计系统',
    desc: '颜色、字体、间距、动效的统一规范,所有页面共享同一套视觉语言。',
    tag: '设计',
    est: '2026-08',
  },
  {
    title: 'Astro 6 SEO 实战',
    desc: '从 sitemap、RSS、OG 到结构化数据,讲清楚每个细节的最佳实践。',
    tag: '技术',
    est: '2026-09',
  },
];
---

<BaseLayout
  title="Blog - Azek431"
  description="博客筹备中,先看看写作计划与草稿列表。"
>
  <Breadcrumb items={[{ label: '首页', href: '/' }, { label: 'Blog' }]} />

  <section class="page-hero blog-hero">
    <p class="eyebrow">Blog</p>
    <h1>博客筹备中</h1>
    <p class="page-hero-text">
      想认真写一些东西——技术随笔、设计笔记、长期思考。
      下面是写作计划、标签体系和当前草稿。
    </p>
    <div class="blog-meta">
      <span class="blog-meta-item"><span class="blog-dot tone-in-progress"></span>4 项计划</span>
      <span class="blog-meta-item"><span class="blog-dot tone-planning"></span>3 篇草稿</span>
      <span class="blog-meta-item">预计 2026 Q3 上线</span>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Plan</p>
      <h2>写作计划</h2>
      <p class="section-sub">分四步把博客体系搭起来,每一步都围绕「更好写、更好读」展开。</p>
    </div>

    <ol class="blog-plan">
      {plans.map((p) => (
        <li class={'blog-plan-item tone-' + p.state}>
          <div class="blog-plan-rail">
            <span class="blog-plan-num">{String(p.num).padStart(2, '0')}</span>
            <span class="blog-plan-line"></span>
          </div>
          <div class="blog-plan-content">
            <div class="blog-plan-head">
              <span class="blog-plan-tag">{p.tag}</span>
              <span class="blog-plan-state">{p.state === 'in-progress' ? '进行中' : '规划中'}</span>
            </div>
            <h3 class="blog-plan-title">{p.title}</h3>
            <p class="blog-plan-desc">{p.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Drafts</p>
      <h2>草稿列表</h2>
      <p class="section-sub">已经在写、但还没打磨好发布的内容,先列个目录占位。</p>
    </div>

    <div class="blog-drafts">
      {drafts.map((d) => (
        <article class="blog-draft">
          <header class="blog-draft-head">
            <span class="blog-draft-tag">{d.tag}</span>
            <span class="blog-draft-est">预计 {d.est}</span>
          </header>
          <h3 class="blog-draft-title">{d.title}</h3>
          <p class="blog-draft-desc">{d.desc}</p>
          <div class="blog-draft-foot">
            <span class="blog-draft-status"><span class="blog-dot tone-in-progress"></span>撰写中</span>
            <span class="blog-draft-hint">敬请期待</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="now-cta">
      <p class="eyebrow">Stay tuned</p>
      <h2>想第一时间看到更新?</h2>
      <p>RSS 已经把现有项目与 Now 同步出去,博客上线后会再加一条专门的 feed。</p>
      <a class="cta-btn" href="/rss.xml">订阅 RSS</a>
    </div>
  </section>
</BaseLayout>
