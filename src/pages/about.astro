---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { siteConfig } from '../data/site';

const principles = [
  {
    title: '长期维护',
    desc: '我更喜欢能持续迭代的项目，而不是只做一次就放弃的页面。',
  },
  {
    title: '真实记录',
    desc: '把学习、开发、踩坑和优化过程留下来，让项目本身也成为成长记录。',
  },
  {
    title: '简洁可用',
    desc: '页面可以好看，但更重要的是稳定、快速、清晰和容易继续维护。',
  },
];

const tracks = [
  { label: 'AI', value: '工具、提示词、自动化实验' },
  { label: 'Web', value: 'Astro、前端、个人网站' },
  { label: 'Open', value: 'GitHub 项目和公开记录' },
];
---

<BaseLayout title="关于 · Azek431" description="关于 Azek431、个人主站、项目方向和长期维护理念。">
  <Breadcrumb items={[{ label: '关于', href: '/about/' }]} />

  <section class="page-v2-hero about-hero-v2">
    <div>
      <p class="page-v2-kicker">About</p>
      <h1>关于这个数字空间</h1>
      <p>
        这个主站是我整理个人内容和项目入口的起点。它会连接我的项目、
        学习记录、技术实践和公开链接，也会随着我的开发习惯持续演进。
      </p>
    </div>

    <aside class="about-profile-v2">
      <p>Azek431</p>
      <h2>{siteConfig.name}</h2>
      <span>{siteConfig.description}</span>

      <div>
        {
          tracks.map((item) => (
            <article>
              <strong>{item.label}</strong>
              <span>{item.value}</span>
            </article>
          ))
        }
      </div>
    </aside>
  </section>

  <section class="section-v2">
    <div class="section-head-v2">
      <p>Principles</p>
      <h2>我希望这个站点保持的方向</h2>
      <span>
        个人网站不是一次性作品，而是长期维护的系统。结构、视觉和内容都应该为后续扩展服务。
      </span>
    </div>

    <div class="principle-grid-v2">
      {
        principles.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="about-narrative-v2">
    <p>
      我希望这个网站不只是一个静态页面，而是一个长期维护的个人数字空间。
      它会把项目、工具、文章、实验和公开入口统一整理起来，也会记录每一次设计和工程上的优化。
    </p>

    <div>
      <a class="ui-button ui-button-primary" href="/projects/">查看项目</a>
      <a class="ui-button ui-button-secondary" href={siteConfig.github}>GitHub</a>
    </div>
  </section>
</BaseLayout>
