---
import BaseLayout from '../layouts/BaseLayout.astro';
import { searchItems } from '../data/search';

const counts = {
  total: searchItems.length,
  Page: searchItems.filter((i) => i.category === 'Page').length,
  Project: searchItems.filter((i) => i.category === 'Project').length,
  Link: searchItems.filter((i) => i.category === 'Link').length,
  Update: searchItems.filter((i) => i.category === 'Update').length,
  Changelog: searchItems.filter((i) => i.category === 'Changelog').length,
};

const categories = ['全部', 'Page', 'Project', 'Link', 'Update', 'Changelog'];
const serialized = JSON.stringify(searchItems);
---

<BaseLayout title="搜索 · Azek431" description="跨页面、项目、链接、更新日志的站内搜索。">
  <section class="section">
    <!-- Hero -->
    <div class="section-heading">
      <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-faint); margin-bottom: var(--space-2);">Command Search</p>
      <h1>站内搜索</h1>
      <p>跨 {counts.total} 条内容索引搜索页面、项目、链接和更新记录。输入关键词即可实时筛选，按回车可以打开第一条结果。</p>
    </div>

    <!-- Search Console -->
    <div class="search-console" role="search">
      <div style="display: flex; align-items: center; gap: var(--space-3);">
        <span style="font-size: var(--text-lg); color: var(--color-text-faint);">/</span>
        <input
          id="site-search"
          type="search"
          placeholder="搜索项目、链接、页面、更新..."
          autocomplete="off"
          data-search-input
        />
      </div>
    </div>

    <!-- Filter -->
    <div class="links-filter" style="margin-top: var(--space-4);">
      {
        categories.map((category, index) => (
          <button
            type="button"
            class="links-filter__chip"
            data-search-category={category}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            <span>{category}</span>
            <span style="margin-left: var(--space-1); opacity: 0.6;">
              {category === '全部' ? counts.total : counts[category as keyof typeof counts]}
            </span>
          </button>
        ))
      }
    </div>

    <!-- Results -->
    <div class="search-results" style="margin-top: var(--space-6);" aria-live="polite">
      <p data-search-hint style="font-size: var(--text-sm); color: var(--color-text-muted);">输入关键词开始搜索，也可以直接点击分类查看索引。</p>

      <ol data-search-results>
        {
          searchItems.slice(0, 30).map((item) => (
            <li data-search-static>
              <a class="search-result" href={item.href}>
                <span>{item.category}</span>
                <strong>{item.title}</strong>
                <small>{item.desc}</small>
              </a>
            </li>
          ))
        }
      </ol>

      <div data-search-empty hidden style="text-align: center; padding: var(--space-6); border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-bg-raised);">
        <h2>没有匹配的结果</h2>
        <p>试试换一个关键词，或直接查看项目、链接和更新日志。</p>
        <div style="display: flex; gap: var(--space-3); margin-top: var(--space-4);">
          <a class="button button-secondary" href="/projects/">所有项目</a>
          <a class="button button-secondary" href="/links/">链接集合</a>
          <a class="button button-secondary" href="/changelog/">更新日志</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ serialized }}>
  (function () {
    var items = JSON.parse(serialized);
    var input = document.querySelector('[data-search-input]');
    var results = document.querySelector('[data-search-results]');
    var empty = document.querySelector('[data-search-empty]');
    var hint = document.querySelector('[data-search-hint]');
    var buttons = Array.prototype.slice.call(document.querySelectorAll('[data-search-category]'));

    if (!input || !results) return;

    var activeCategory = '全部';

    var normalize = function (value) {
      return String(value || '')
        .toLowerCase()
        .trim();
    };

    var scoreItem = function (item, query) {
      if (!query) return 1;

      var title = normalize(item.title);
      var desc = normalize(item.desc);
      var href = normalize(item.href);
      var tags = normalize((item.tags || []).join(' '));

      if (title === query) return 100;
      if (title.indexOf(query) >= 0) return 80;
      if (tags.indexOf(query) >= 0) return 62;
      if (desc.indexOf(query) >= 0) return 42;
      if (href.indexOf(query) >= 0) return 24;

      return 0;
    };

    var render = function () {
      var query = normalize(input.value);

      var matched = items
        .map(function (item) {
          return {
            item: item,
            score: scoreItem(item, query),
          };
        })
        .filter(function (entry) {
          var categoryMatch = activeCategory === '全部' || entry.item.category === activeCategory;
          return categoryMatch && entry.score > 0;
        })
        .sort(function (a, b) {
          return b.score - a.score;
        })
        .slice(0, 40);

      results.innerHTML = matched
        .map(function (entry) {
          var item = entry.item;
          var tags = (item.tags || [])
            .slice(0, 4)
            .map(function (tag) {
              return '<em>#' + tag + '</em>';
            })
            .join('');

          return (
            '<li><a href="' +
            item.href +
            '"><span>' +
            item.category +
            '</span><strong>' +
            item.title +
            '</strong><small>' +
            item.desc +
            '</small><div>' +
            tags +
            '</div></a></li>'
          );
        })
        .join('');

      if (hint) hint.hidden = query.length > 0 || activeCategory !== '全部';
      if (empty) empty.hidden = matched.length !== 0;
    };

    buttons.forEach(function (button) {
      button.addEventListener('click', function () {
        activeCategory = button.getAttribute('data-search-category') || '全部';

        buttons.forEach(function (btn) {
          btn.setAttribute('aria-pressed', btn === button ? 'true' : 'false');
        });

        render();
      });
    });

    input.addEventListener('input', render);

    input.addEventListener('keydown', function (event) {
      if (event.key !== 'Enter') return;
      var first = results.querySelector('a');
      if (first) {
        event.preventDefault();
        first.click();
      }
    });

    render();
  })();
</script>
