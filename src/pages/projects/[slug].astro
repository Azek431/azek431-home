---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { projectDetails, type ProjectDetail } from '../../data/projects';

type DetailLink = {
  label: string;
  href: string;
  primary?: boolean;
  external: boolean;
};

export function getStaticPaths() {
  return projectDetails.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: ProjectDetail };

if (!project) {
  return Astro.redirect('/projects/');
}

const index = projectDetails.findIndex((item) => item.slug === project.slug);
const prevProject =
  index > 0 ? projectDetails[index - 1] : projectDetails[projectDetails.length - 1];
const nextProject =
  index < projectDetails.length - 1 ? projectDetails[index + 1] : projectDetails[0];

const allTags = project.tags || [];
const features = project.features || [];
const highlights = project.highlights || [];

const links: DetailLink[] = [];

if (project.websiteUrl) {
  links.push({
    label: '访问网站',
    href: project.websiteUrl,
    primary: true,
    external: true,
  });
}

if (project.githubUrl) {
  links.push({
    label: 'GitHub 仓库',
    href: project.githubUrl,
    external: true,
  });
}

if (project.giteeUrl) {
  links.push({
    label: 'Gitee 镜像',
    href: project.giteeUrl,
    external: true,
  });
}

const sharedTags = (a: ProjectDetail, b: ProjectDetail) =>
  (a.tags || []).filter((tag) => (b.tags || []).includes(tag)).length;

const relatedProjects = projectDetails
  .filter((item) => item.slug !== project.slug)
  .map((item) => ({
    project: item,
    score: (item.category === project.category ? 3 : 0) + sharedTags(item, project),
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 2)
  .map((item) => item.project);
---

<BaseLayout title={`${project.title} · Azek431`} description={project.description}>
  <Breadcrumb
    items={[
      { label: '项目', href: '/projects/' },
      { label: project.title, href: `/projects/${project.slug}/` },
    ]}
  />

  <section class="project-detail-hero-v2" style={`--project-accent: ${project.accent}`}>
    <div>
      <p class="page-v2-kicker">Project · {project.category}</p>
      <h1>{project.title}</h1>
      <p>{project.description}</p>

      <div class="project-detail-meta-v2">
        <span>{project.status}</span>
        {project.lastUpdated && <span>更新于 {project.lastUpdated}</span>}
        {allTags.slice(0, 3).map((tag) => <span>{tag}</span>)}
      </div>

      {
        links.length > 0 && (
          <div class="project-detail-actions-v2">
            {links.map((link) => (
              <a
                class:list={[
                  'ui-button',
                  link.primary ? 'ui-button-primary' : 'ui-button-secondary',
                ]}
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noreferrer' : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    {
      highlights.length > 0 && (
        <aside class="project-detail-data-v2">
          <p>Project Data</p>
          {highlights.map((item) => (
            <article>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </article>
          ))}
        </aside>
      )
    }
  </section>

  <section class="section-v2 split-v2">
    <article class="project-story-v2">
      <p>Overview</p>
      <h2>项目说明</h2>
      <div>
        {project.longDescription || project.description}
      </div>
    </article>

    <aside class="project-tags-v2">
      <p>Tech Stack</p>
      <h2>使用技术</h2>
      <div>{allTags.map((tag) => <span>{tag}</span>)}</div>
    </aside>
  </section>

  {
    features.length > 0 && (
      <section class="section-v2">
        <div class="section-head-v2">
          <p>Features</p>
          <h2>特性 / 亮点</h2>
          <span>这些是这个项目当前最值得关注的部分。</span>
        </div>

        <div class="feature-grid-v2">
          {features.map((feature, featureIndex) => (
            <article>
              <span>{String(featureIndex + 1).padStart(2, '0')}</span>
              <p>{feature}</p>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    relatedProjects.length > 0 && (
      <section class="section-v2">
        <div class="section-head-v2">
          <p>Related</p>
          <h2>相关项目</h2>
          <span>根据分类和标签匹配到的其他项目。</span>
        </div>

        <div class="project-showcase">
          {relatedProjects.map((item) => (
            <article class="project-showcase-card" style={`--project-accent: ${item.accent}`}>
              <div>
                <p>{item.category}</p>
                <h3>{item.title}</h3>
                <span>{item.status}</span>
              </div>

              <p>{item.description}</p>

              <ul>
                {(item.tags || []).slice(0, 3).map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>

              <a href={`/projects/${item.slug}/`}>查看项目 →</a>
            </article>
          ))}
        </div>
      </section>
    )
  }

  <nav class="project-neighbor-v2" aria-label="项目切换">
    <a href={`/projects/${prevProject.slug}/`}>
      <span>← 上一个</span>
      <strong>{prevProject.title}</strong>
    </a>

    <a href="/projects/">
      <span>返回</span>
      <strong>项目列表</strong>
    </a>

    <a href={`/projects/${nextProject.slug}/`}>
      <span>下一个 →</span>
      <strong>{nextProject.title}</strong>
    </a>
  </nav>
</BaseLayout>
