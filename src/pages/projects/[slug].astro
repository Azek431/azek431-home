---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projectDetails, getProjectBySlug } from '../../data/projects';

export function getStaticPaths() {
  return projectDetails.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
if (!project) return Astro.redirect('/projects/');

import { projectDetails } from '../../data/projects';
const idx = projectDetails.findIndex((p) => p.slug === project.slug);
const prevProject = idx > 0 ? projectDetails[idx - 1] : projectDetails[projectDetails.length - 1];
const nextProject = idx < projectDetails.length - 1 ? projectDetails[idx + 1] : projectDetails[0];

const statusTone =
  project.status === '已上线' ? 'success'
  : project.status === '维护中' ? 'warning'
  : project.status === '计划中' ? 'accent'
  : 'muted';

const accentStyle = '--accent-color:' + project.accent + ';';
const allTags = project.tags || [];
const features = project.features || [];
const highlights = project.highlights || [];
const allLinks = [
  project.websiteUrl && { label: '访问网站', href: project.websiteUrl, primary: true, external: true },
  project.githubUrl   && { label: 'GitHub 仓库', href: project.githubUrl, external: true },
  project.giteeUrl    && { label: 'Gitee 镜像', href: project.giteeUrl, external: true },
].filter(Boolean);
---
<BaseLayout
  title={project.title + ' - Azek431'}
  description={project.description}
>
  <section class="page-hero detail-hero" style={accentStyle}>
    <p class="eyebrow">Project · {project.category}</p>
    <h1>{project.title}</h1>
    <p class="page-hero-text">{project.description}</p>

    <div class="project-meta-row">
      <span class="status-pill" data-tone={statusTone}>{project.status}</span>
      {project.lastUpdated && <span class="meta-pill">更新于 {project.lastUpdated}</span>}
      {allTags.slice(0, 3).map((t) => <span class="meta-pill">{t}</span>)}
    </div>
  </section>

  <section class="section">
    <div class="detail-grid">
      <div class="detail-main">
        <p class="detail-long">{project.longDescription}</p>

        {features.length > 0 && (
          <>
            <h2 class="detail-h2">特性 / 亮点</h2>
            <ul class="detail-features">
              {features.map((f) => (
                <li>
                  <span class="detail-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  </span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </>
        )}

        {allTags.length > 0 && (
          <>
            <h2 class="detail-h2">使用技术</h2>
            <div class="detail-tags">
              {allTags.map((t) => <span class="detail-tag">{t}</span>)}
            </div>
          </>
        )}

        <a class="detail-back" href="/projects/">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          返回项目列表
        </a>
      </div>

      <nav class="prev-next" aria-label="项目分页">
        <a class="prev-next-link prev" href={'/projects/' + prevProject.slug + '/'}>
          <span class="pn-label">← 上一篇</span>
          <span class="pn-title">{prevProject.title}</span>
        </a>
        <a class="prev-next-link next" href={'/projects/' + nextProject.slug + '/'}>
          <span class="pn-label">下一篇 →</span>
          <span class="pn-title">{nextProject.title}</span>
        </a>
      </nav>

      <aside class="detail-side">
        {highlights.length > 0 && (
          <div class="detail-card">
            <h3>项目数据</h3>
            <ul class="detail-stats">
              {highlights.map((h) => (
                <li>
                  <span class="label">{h.label}</span>
                  <span class="value">{h.value}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {allLinks.length > 0 && (
          <div class="detail-card">
            <h3>相关链接</h3>
            <ul class="detail-link-list">
              {allLinks.map((l) => (
                <li>
                  <a class="detail-link-card" href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener noreferrer' : undefined}>
                    <span>{l.label}</span>
                    <svg class="arrow" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17 17 7"/><path d="M8 7h9v9"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="detail-card detail-card-soft">
          <h3>下一步</h3>
          <p>如果你对这个项目感兴趣,可以通过上面的链接访问,或返回项目列表查看其他项目。</p>
          <a class="button secondary" href="/links/?tag={encodeURIComponent(project.category)}">查看相关链接</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
