---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projectDetails, type ProjectDetail } from '../../data/projects';

type DetailLink = {
  label: string;
  href: string;
  primary?: boolean;
  external: boolean;
};

export function getStaticPaths() {
  return projectDetails.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: ProjectDetail };

if (!project) {
  return Astro.redirect('/projects/');
}

const index = projectDetails.findIndex((item) => item.slug === project.slug);
const prevProject =
  index > 0 ? projectDetails[index - 1] : projectDetails[projectDetails.length - 1];
const nextProject =
  index < projectDetails.length - 1 ? projectDetails[index + 1] : projectDetails[0];

const allTags = project.tags || [];
const features = project.features || [];
const highlights = project.highlights || [];

const links: DetailLink[] = [];

if (project.websiteUrl) {
  links.push({
    label: '访问网站',
    href: project.websiteUrl,
    primary: true,
    external: true,
  });
}

if (project.githubUrl) {
  links.push({
    label: 'GitHub 仓库',
    href: project.githubUrl,
    external: true,
  });
}

if (project.giteeUrl) {
  links.push({
    label: 'Gitee 镜像',
    href: project.giteeUrl,
    external: true,
  });
}

const sharedTags = (a: ProjectDetail, b: ProjectDetail) =>
  (a.tags || []).filter((tag) => (b.tags || []).includes(tag)).length;

const relatedProjects = projectDetails
  .filter((item) => item.slug !== project.slug)
  .map((item) => ({
    project: item,
    score: (item.category === project.category ? 3 : 0) + sharedTags(item, project),
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 2)
  .map((item) => item.project);
---

<BaseLayout title={`${project.title} · Azek431`} description={project.description}>
  <section class="section">
    <!-- Hero -->
    <div class="detail-hero">
      <div style="display: flex; gap: var(--space-2); margin-bottom: var(--space-3);">
        <span class="tag">{project.category}</span>
        <span class="tag tag-accent">{project.status}</span>
      </div>
      <h1>{project.title}</h1>
      <p>{project.description}</p>

      <div class="detail-meta">
        {project.lastUpdated && <span class="tag">更新于 {project.lastUpdated}</span>}
        {allTags.slice(0, 5).map((tag) => <span class="tag">{tag}</span>)}
      </div>

      {links.length > 0 && (
        <div style="display: flex; gap: var(--space-3); margin-top: var(--space-4); flex-wrap: wrap;">
          {links.map((link) => (
            <a
              class={link.primary ? 'button button-primary' : 'button button-secondary'}
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noreferrer' : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Highlights + Sidebar -->
    {highlights.length > 0 && (
      <div class="detail-grid">
        <div class="detail-content">
          <h2>项目说明</h2>
          <p>{project.longDescription || project.description}</p>

          {features.length > 0 && (
            <>
              <h2>特性 / 亮点</h2>
              <ul class="detail-features">
                {features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>
            </>
          )}
        </div>

        <aside class="detail-sidebar">
          {highlights.length > 0 && (
            <div class="detail-sidebar__card">
              <h3>Project Data</h3>
              <ul class="detail-stats">
                {highlights.map((item) => (
                  <li>
                    <span class="label">{item.label}</span>
                    <span class="value">{item.value}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="detail-sidebar__card">
            <h3>Tech Stack</h3>
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
              {allTags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>

          <div class="detail-sidebar__card">
            <h3>Links</h3>
            <div class="detail-links">
              {links.map((link) => (
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noreferrer' : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    )}

    {highlights.length === 0 && (
      <div class="detail-content">
        <h2>项目说明</h2>
        <p>{project.longDescription || project.description}</p>
        {features.length > 0 && (
          <>
            <h2>特性 / 亮点</h2>
            <ul class="detail-features">
              {features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </>
        )}
        <div style="margin-top: var(--space-6);">
          <h2>Tech Stack</h2>
          <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
            {allTags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>
    )}

    <!-- Related Projects -->
    {relatedProjects.length > 0 && (
      <div style="margin-top: var(--space-12);">
        <div class="section-heading">
          <p style="font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-faint); margin-bottom: var(--space-2);">Related</p>
          <h2>相关项目</h2>
          <p style="font-size: var(--text-sm); color: var(--color-text-muted);">根据分类和标签匹配到的其他项目。</p>
        </div>

        <div class="card-grid">
          {relatedProjects.map((item) => (
            <div class="card">
              <p style="font-size: var(--text-xs); color: var(--color-text-faint); margin-bottom: var(--space-1);">{item.category}</p>
              <h3>{item.title}</h3>
              <span class="tag tag-accent" style="margin-bottom: var(--space-2); display: inline-block;">{item.status}</span>
              <p>{item.description}</p>
              <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-2);">
                {(item.tags || []).slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <a href={`/projects/${item.slug}/`} style="display: inline-flex; margin-top: var(--space-3); font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted);">查看项目 →</a>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Nav -->
    <nav aria-label="项目切换" style="display: flex; justify-content: space-between; gap: var(--space-4); margin-top: var(--space-10); padding-top: var(--space-6); border-top: 1px solid var(--color-border);">
      <a href={`/projects/${prevProject.slug}/`} style="flex: 1;">
        <span style="font-size: var(--text-xs); color: var(--color-text-faint);">← 上一个</span>
        <strong style="display: block; font-size: var(--text-sm);">{prevProject.title}</strong>
      </a>
      <a href="/projects/" style="flex: 1; text-align: center;">
        <span style="font-size: var(--text-xs); color: var(--color-text-faint);">返回</span>
        <strong style="display: block; font-size: var(--text-sm);">项目列表</strong>
      </a>
      <a href={`/projects/${nextProject.slug}/`} style="flex: 1; text-align: right;">
        <span style="font-size: var(--text-xs); color: var(--color-text-faint);">下一个 →</span>
        <strong style="display: block; font-size: var(--text-sm);">{nextProject.title}</strong>
      </a>
    </nav>
  </section>
</BaseLayout>
