---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { links } from '../data/site';
import { siteUpdatedDate } from '../data/time';

const categories = ['全部', ...Array.from(new Set(links.map((l) => l.category)))];

const categoryMeta: Record<
  string,
  { title: string; desc: string; tone: 'green' | 'blue' | 'violet' | 'amber' }
> = {
  Main: {
    title: '主入口',
    desc: '最常用的公开主页、代码平台和当前主站入口。',
    tone: 'green',
  },
  Site: {
    title: '站内核心',
    desc: '关于、项目、博客和主站核心页面。',
    tone: 'blue',
  },
  Extra: {
    title: '扩展入口',
    desc: 'Now、Uses、统计、订阅源和更新记录。',
    tone: 'violet',
  },
};

const groups = categories
  .filter((category) => category !== '全部')
  .map((category) => ({
    category,
    ...(categoryMeta[category] || {
      title: category,
      desc: '这一组链接用于补充个人主站的公开入口。',
      tone: 'amber' as const,
    }),
    items: links.filter((link) => link.category === category),
  }));

const externalCount = links.filter((link) => link.href.startsWith('http')).length;
const internalCount = links.length - externalCount;
---

<BaseLayout title="链接 · Azek431" description="Azek431 的公开入口、站内导航、项目链接和订阅资源。">
  <Breadcrumb items={[{ label: '链接', href: '/links/' }]} />

  <section class="page-v2-hero links-hero-v2">
    <div>
      <p class="page-v2-kicker">Resource Hub</p>
      <h1>公开入口</h1>
      <p>
        这里把主站、代码平台、项目入口、订阅源和站内页面集中整理起来，
        方便快速找到不同内容，也方便后续扩展更多公开链接。
      </p>
    </div>

    <div class="page-v2-stat-grid">
      <article data-tone="green">
        <strong>{links.length}</strong>
        <span>全部链接</span>
      </article>
      <article data-tone="blue">
        <strong>{internalCount}</strong>
        <span>站内入口</span>
      </article>
      <article data-tone="violet">
        <strong>{externalCount}</strong>
        <span>外部入口</span>
      </article>
      <article data-tone="amber">
        <strong>{siteUpdatedDate}</strong>
        <span>最近构建</span>
      </article>
    </div>
  </section>

  <section class="link-filter-v2" aria-label="链接筛选">
    {
      categories.map((category, index) => (
        <button
          type="button"
          class="link-filter-pill"
          data-link-filter={category}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {category}
        </button>
      ))
    }
  </section>

  <section class="resource-groups-v2" aria-label="链接分组">
    {
      groups.map((group) => (
        <article class="resource-group-v2" data-group={group.category} data-tone={group.tone}>
          <div class="resource-group-head">
            <div>
              <h2>{group.title}</h2>
              <span>{group.desc}</span>
            </div>
            <strong>{group.items.length}</strong>
          </div>

          <div class="resource-card-grid">
            {group.items.map((link) => (
              <a
                class="resource-card-v2"
                href={link.href}
                data-link-card
                data-category={link.category}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
              >
                <div>
                  <strong>{link.name}</strong>
                  <span>{link.description}</span>
                </div>

                <ul>
                  {link.tags.slice(0, 3).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </a>
            ))}
          </div>
        </article>
      ))
    }

    <p class="resource-empty-v2" data-link-empty hidden aria-live="polite">
      这个分类下暂时没有链接。
    </p>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var buttons = Array.prototype.slice.call(document.querySelectorAll('[data-link-filter]'));
    var cards = Array.prototype.slice.call(document.querySelectorAll('[data-link-card]'));
    var groups = Array.prototype.slice.call(document.querySelectorAll('[data-group]'));
    var empty = document.querySelector('[data-link-empty]');

    if (!buttons.length || !cards.length) return;

    var apply = function (category) {
      var shown = 0;

      buttons.forEach(function (button) {
        var active = button.getAttribute('data-link-filter') === category;
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      cards.forEach(function (card) {
        var match = category === '全部' || card.getAttribute('data-category') === category;
        card.hidden = !match;
        if (match) shown += 1;
      });

      groups.forEach(function (group) {
        var groupCategory = group.getAttribute('data-group');
        var match = category === '全部' || groupCategory === category;
        group.hidden = !match;
      });

      if (empty) empty.hidden = shown !== 0;
    };

    buttons.forEach(function (button) {
      button.addEventListener('click', function () {
        apply(button.getAttribute('data-link-filter') || '全部');
      });
    });

    apply('全部');
  })();
</script>
