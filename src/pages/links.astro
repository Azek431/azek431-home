---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import NavCard from '../components/NavCard.astro';
import { links } from '../data/site';
import Breadcrumb from '../components/Breadcrumb.astro';
import NavCard from '../components/NavCard.astro';
import { links } from '../data/site';

const categories = ['全部', ...Array.from(new Set(links.map((l) => l.category)))];
---

<BaseLayout title="链接 - Azek431" description="Azek431 的公开链接集合，用于整理 GitHub、项目入口和其他公开资源。">
  <Breadcrumb items={[{ label: '首页', href: '/' }, { label: '链接' }]} />
  <PageHero
    eyebrow="Links"
    title="链接集合"
    description="这里会整理我的 GitHub、项目入口、个人页面和其他公开链接,让所有内容入口更加清晰。"
    meta={[
      { label: '总数', value: links.length + ' 条' },
      { label: '分类', value: '6 类' },
      { label: '最近', value: '2026-06-04' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Resources</p>
      <h2>公开入口</h2>
      <p>这些链接会作为个人主站的长期导航入口，方便快速访问不同内容。</p>
    </div>

    <div class="filter-chips" role="tablist" aria-label="按分类筛选">
      {categories.map((c, i) => (
        <button
          type="button"
          class:list={['filter-chip', { active: i === 0 }]}
          data-filter={c === '全部' ? '*' : c}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {c}
        </button>
      ))}
    </div>

    <div class="content-grid links-grid">
      {links.map((link) => (
        <div class="link-cell" data-category={link.category}>
          <div class="link-wrap">
            <NavCard
              title={link.name}
              description={link.description}
              href={link.href}
              status="公开链接"
              statusTone="accent"
              category={link.category}
              icon={link.name[0]}
              iconTone={link.category === 'Code' ? 'success' : link.category === 'Writing' ? 'accent' : 'primary'}
              tags={link.tags}
              accent={link.category === 'Code' ? '#6ee7b7' : link.category === 'Writing' ? '#c4b5fd' : link.category === 'Profile' ? '#fcd34d' : '#a8c8ff'}
            />
            <button
              type="button"
              class="link-copy"
              data-copy-url={link.href}
              aria-label={'复制 ' + link.name + ' 链接'}
              title="复制链接"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <p class="filter-empty" hidden>这个分类下暂时没有链接。</p>
  </section>

  <script is:inline>
    (function () {
      var chips = document.querySelectorAll('.filter-chip');
      var cells = document.querySelectorAll('.link-cell');
      var empty = document.querySelector('.filter-empty');
      if (!chips.length || !cells.length) return;

      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          var filter = chip.getAttribute('data-filter') || '*';
          chips.forEach(function (c) {
            c.classList.remove('active');
            c.setAttribute('aria-selected', 'false');
          });
          chip.classList.add('active');
          chip.setAttribute('aria-selected', 'true');

          var shown = 0;
          cells.forEach(function (cell) {
            var cat = cell.getAttribute('data-category');
            var match = filter === '*' || cat === filter;
            cell.classList.toggle('filter-hidden', !match);
            if (match) shown++;
          });
          if (empty) empty.hidden = shown !== 0;
        });
      });
        // Apply ?tag= filter from query string
        try {
          var params = new URLSearchParams(window.location.search);
          var qt = params.get('tag');
          if (qt) {
            var matchChip = null;
            chips.forEach(function (c) {
              if ((c.getAttribute('data-filter') || '') === qt) matchChip = c;
            });
            if (matchChip) matchChip.click();
          }
        } catch (e) { /* ignore */ }
    })();
  </script>
</BaseLayout>
