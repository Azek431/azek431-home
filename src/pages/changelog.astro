---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { changelog } from '../data/changelog';

const totalChanges = changelog.reduce((acc, item) => acc + item.changes.length, 0);

const toneLabel: Record<string, string> = {
  major: '大版本',
  minor: '小版本',
  patch: '补丁',
};

const counts = [
  { label: '全部版本', value: changelog.length, tone: 'blue' },
  { label: '总改动', value: totalChanges, tone: 'green' },
  {
    label: '大版本',
    value: changelog.filter((item) => item.tone === 'major').length,
    tone: 'violet',
  },
  {
    label: '补丁',
    value: changelog.filter((item) => item.tone === 'patch').length,
    tone: 'amber',
  },
];
---

<BaseLayout
  title="更新日志 · Azek431"
  description="Azek431 个人主站的版本更新、功能变化和维护记录。"
>
  <Breadcrumb items={[{ label: '更新日志', href: '/changelog/' }]} />

  <section class="page-v2-hero changelog-hero-v2">
    <div>
      <p class="page-v2-kicker">Changelog</p>
      <h1>更新日志</h1>
      <p>这里记录主站每一次重要调整：页面结构、视觉系统、SEO、数据、交互和工程化流程。</p>
    </div>

    <div class="page-v2-stat-grid">
      {
        counts.map((item) => (
          <article data-tone={item.tone}>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))
      }
    </div>
  </section>

  <section class="changelog-timeline-v2">
    {
      changelog.map((entry, index) => (
        <article data-tone={entry.tone || 'minor'}>
          <div class="changelog-index-v2">{String(index + 1).padStart(2, '0')}</div>

          <div class="changelog-entry-v2">
            <div>
              <p>
                {entry.version} · {entry.date} · {toneLabel[entry.tone || 'minor']}
              </p>
              <h2>{entry.title}</h2>
            </div>

            <ul>
              {entry.changes.map((change) => (
                <li>{change}</li>
              ))}
            </ul>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
