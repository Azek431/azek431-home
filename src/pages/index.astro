---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavCard from '../components/NavCard.astro';
import Roadmap from '../components/Roadmap.astro';
import { homeCards, siteConfig, recentUpdates } from '../data/site';

const liveProjects = homeCards.filter((c) => c.status === '项目导航' || c.status === '链接集合').length;
const externalLinks = homeCards.filter((c) => c.status === '外部链接').length;
const upcoming = homeCards.filter((c) => c.status === '即将上线').length;
const recentCount = recentUpdates.length;
const progressPct = Math.min(100, Math.round((recentCount / 6) * 100));

function daysAgo(dateStr: string): string {
  const then = new Date(dateStr + 'T00:00:00Z').getTime();
  const now = Date.now();
  const d = Math.floor((now - then) / 86400000);
  if (d < 1) return '今天';
  if (d === 1) return '昨天';
  if (d < 30) return d + ' 天前';
  if (d < 365) return Math.floor(d / 30) + ' 个月前';
  return Math.floor(d / 365) + ' 年前';
}

const quickJumps = [
  { label: '项目展示',  href: '/projects/', desc: 'Azek431 Home / 资料库 / Blog' },
  { label: 'GitHub',    href: siteConfig.github, desc: '代码 · 仓库 · 实践记录' },
  { label: '关于我',    href: '/about/',   desc: '兴趣方向 · 内容规划 · 联系方式' },
  { label: 'Now',       href: '/now/',     desc: '最近在做什么 / 读什么' },
  { label: 'Uses',      href: '/uses/',    desc: '日常装备 / 工具栈' },
  { label: '链接集合',  href: '/links/',   desc: '所有公开入口 · 按标签筛选' },
];
---
<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <div class="home-pulse" role="group" aria-label="实时状态">
    <div class="home-pulse-item">
      <span class="home-pulse-label">Mood</span>
      <span class="home-pulse-value"><span class="home-pulse-dot"></span>正在打磨细节</span>
    </div>
    <div class="home-pulse-item">
      <span class="home-pulse-label">主题</span>
      <span class="home-pulse-value">设计系统 + Astro 6</span>
    </div>
    <div class="home-pulse-item">
      <span class="home-pulse-label">阅读</span>
      <span class="home-pulse-value">Designing Data-Intensive Apps</span>
    </div>
    <div class="home-pulse-item">
      <span class="home-pulse-label">Next</span>
      <span class="home-pulse-value"><a href="/now/">看 /now →</a></span>
    </div>
  </div>

  <nav class="home-quicklinks" aria-label="快捷入口">
    <span class="home-quicklinks-label">快捷入口</span>
    <ul class="home-quicklinks-list">
      <li><a href="/projects/"><span>查看所有项目</span><svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></a></li>
      <li><a href="/now/"><span>现在在做什么</span><svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></a></li>
      <li><a href="/rss.xml" target="_blank" rel="noreferrer noopener"><span>订阅 RSS</span><svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></a></li>
      <li><a href={siteConfig.github} target="_blank" rel="noreferrer noopener"><span>访问 GitHub</span><svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></a></li>
    </ul>
  </nav>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-main">
        <p class="eyebrow">
          Personal Digital Space
          <span class="eyebrow-meta">最后更新 {recentUpdates[0].date} · {daysAgo(recentUpdates[0].date)}</span>
        </p>
        <h1>你好,我是 <span class="grad">Azek431</span>。</h1>
        <p class="hero-text">
          这里是我的个人数字空间。我会在这里整理博客、项目、学习记录和一些有趣的实验,
          也会把项目入口、公开链接和个人内容统一导航到这里。
        </p>

        <ul class="hero-stats" aria-label="主站状态">
          <li>
            <span class="dot"></span>
            <span>主站运行中 · <span class="hero-clock" data-clock></span></span>
          </li>
          <li>
            <span class="dot idle"></span>
            <span>{upcoming} 项内容规划中</span>
          </li>
          <li>
            <span class="dot lab"></span>
            <span>关注 AI · Web · Open Source</span>
          </li>
        </ul>

        <div class="actions">
          <a class="button primary" href="/projects/">
            查看项目
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
          <a class="button secondary" href={siteConfig.github} target="_blank" rel="noreferrer noopener">
            访问 GitHub
          </a>
        </div>
      </div>

      <aside class="hero-side" aria-label="主站信息" data-tilt>
        <h3>主站信息</h3>
        <ul>
          <li><span class="label">状态</span><span class="signal">运行中</span></li>
          <li><span class="label">导航入口</span><span class="value">{homeCards.length} 个</span></li>
          <li><span class="label">已上线项目</span><span class="value">{liveProjects}</span></li>
          <li><span class="label">外部链接</span><span class="value">{externalLinks}</span></li>
          <li><span class="label">技术栈</span><span class="value">Astro · Cloudflare</span></li>
          <li><span class="label">主题</span><span class="value">Dark · Glass</span></li>
        </ul>

        <div class="quick-jump">
          <p class="quick-jump-title">快速跳转</p>
          <ul>
            {quickJumps.map((q) => (
              <li>
                <a class="quick-jump-link" href={q.href} target={q.href.startsWith('http') ? '_blank' : undefined} rel={q.href.startsWith('http') ? 'noreferrer noopener' : undefined}>
                  <span class="qj-label">{q.label}</span>
                  <span class="qj-desc">{q.desc}</span>
                  <svg class="arrow" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Navigation</p>
      <h2>主站导航</h2>
      <p>这个主站会作为我的长期入口,用来连接博客、项目、文档、实验内容和其他公开页面。</p>
    </div>

    <div class="cards">
      {homeCards.map((item) => (
        <NavCard
          title={item.title}
          description={item.description}
          href={item.href}
          status={item.status}
          statusTone={item.status === '即将上线' ? 'muted' : item.status === '外部链接' ? 'accent' : 'success'}
          icon={item.title === 'Blog' ? 'B' : item.title === 'Projects' ? 'P' : item.title === 'GitHub' ? 'G' : 'L'}
          iconTone={item.title === 'Blog' ? 'accent' : item.title === 'GitHub' ? 'success' : 'primary'}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Recent Updates</p>
      <h2>最近更新</h2>
      <p>这里会记录主站、项目和其他内容的最近改动。</p>
    </div>

    <div class="timeline-progress" aria-label="本月更新进度">
      <span>最近 30 天 · {recentCount} 条更新</span>
      <div class="timeline-progress-bar"><div class="timeline-progress-fill" style="width: {progressPct}%"></div></div>
      <span>{progressPct}%</span>
    </div>

    <ol class="timeline" aria-label="最近更新">
      {recentUpdates.map((u, i) => (
        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
            {i < recentUpdates.length - 1 && <span class="timeline-line"></span>}
          </div>
          <a class="timeline-content" href={u.href}>
            <div class="timeline-meta">
              <span class="timeline-tag">{u.tag}</span>
              <time>{u.date} · {daysAgo(u.date)}</time>
            </div>
            <h3>{u.title}</h3>
            <p>{u.desc}</p>
            <svg class="timeline-arrow" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
            </svg>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <Roadmap />

  <section class="section">
    <div class="writing-card">
      <div class="writing-left">
        <p class="eyebrow">
          Currently Writing
          <span class="eyebrow-meta">写于 2026-06-02 · 5 天前</span>
        </p>
        <h2>现在在写</h2>
        <p class="writing-desc">
          最近正在整理一些内容,可能在博客上线后发布。下面是其中一个片段。
        </p>
        <div class="writing-tags">
          <span class="writing-tag"># 设计系统</span>
          <span class="writing-tag"># Astro 6</span>
          <span class="writing-tag"># 主站</span>
        </div>
      </div>
      <div class="writing-right">
        <div class="writing-window">
          <div class="writing-bar">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            <span class="writing-file">draft.md</span>
            <span class="writing-status">
              <span class="writing-status-dot" aria-hidden="true"></span>
              live
            </span>
          </div>
          <pre class="writing-body"><code data-typed></code></pre>
          <div class="writing-footer">
            <span>~ 320 字 · 12 行</span>
            <span>UTF-8 · LF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="about-preview">
      <div>
        <p class="eyebrow">About</p>
        <h2>我正在构建自己的个人网站生态。</h2>
      </div>
      <div>
        <p>
          目前我关注 AI、网站搭建、GitHub 项目部署和软件开发。
          这个站点会从一个简单的主站开始,后续逐步扩展博客、项目展示、文档和实验工具。
        </p>
        <div class="about-stats">
          <div><strong>4</strong><span>导航入口</span></div>
          <div><strong>2</strong><span>已上线项目</span></div>
          <div><strong>∞</strong><span>探索方向</span></div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var el = document.querySelector('[data-clock]');
      if (el) {
        var pad = function (n) { return n < 10 ? '0' + n : '' + n; };
        var tick = function () {
          var d = new Date();
          el.textContent = pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds());
        };
        tick();
        setInterval(tick, 1000);
      }
    })();
  </script>
</BaseLayout>
