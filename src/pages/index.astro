---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeActivityNetwork from '../components/home/HomeActivityNetwork.astro';
import HomeCommand from '../components/home/HomeCommand.astro';
import HomeHero from '../components/home/HomeHero.astro';
import HomeNavigation from '../components/home/HomeNavigation.astro';
import HomeProjects from '../components/home/HomeProjects.astro';
import HomeRoadmap from '../components/home/HomeRoadmap.astro';
import HomeStatusConsole from '../components/home/HomeStatusConsole.astro';
import { links, recentUpdates, siteConfig } from '../data/site';
import { projectDetails } from '../data/projects';
import { relativeDate, siteUpdatedDate } from '../data/time';

const liveProjects = projectDetails.filter((project) => project.status === '已上线').length;
const plannedProjects = projectDetails.length - liveProjects;
const externalLinks = links.filter((link) => link.href.startsWith('http')).length;

const focusItems = [
  {
    title: 'AI',
    desc: '工具、工作流与实验记录',
  },
  {
    title: 'Web',
    desc: 'Astro、前端与网站建设',
  },
  {
    title: 'Open',
    desc: 'GitHub 项目与长期维护',
  },
];

const navigationMatrix = [
  {
    label: 'Project Matrix',
    title: '查看项目',
    href: '/projects/',
    desc: '项目、工具、网站和实验入口。',
    accent: 'blue',
  },
  {
    label: 'Command Search',
    title: '站内搜索',
    href: '/search/',
    desc: '快速检索页面、项目、链接和更新。',
    accent: 'violet',
  },
  {
    label: 'Now Status',
    title: '现在在做',
    href: '/now/',
    desc: '最近状态、关注方向和工具流。',
    accent: 'green',
  },
  {
    label: 'Stats Dashboard',
    title: '站点数据',
    href: '/stats/',
    desc: '查看页面、项目、更新和本地访问统计。',
    accent: 'amber',
  },
];

const featuredProjects = projectDetails.slice(0, 3);
const mainProject = featuredProjects[0];
const sideProjects = featuredProjects.slice(1);

const networkLinks = links.filter((link) =>
  ['GitHub', 'Gitee', '当前主站', 'RSS', 'Sitemap'].includes(link.name),
);

const featuredUpdates = recentUpdates.slice(0, 3);

const phases = [
  {
    step: 'Phase 01',
    title: 'Home System',
    desc: '统一主站首页、项目入口、公开链接和站点状态。',
    status: '已启动',
  },
  {
    step: 'Phase 02',
    title: 'Content Layer',
    desc: '继续完善 Blog、Changelog、Search、RSS 和长期记录。',
    status: '推进中',
  },
  {
    step: 'Phase 03',
    title: 'AI Tools',
    desc: '后续连接 AI 实验、自动化工作流和更多工具型页面。',
    status: '规划中',
  },
];
---

<BaseLayout
  title="Azek431 Digital Nexus"
  description="Azek431 的个人数字中枢，用于连接项目、AI 实验、学习记录、公开入口和长期内容。"
>
  <main class="home-v3">
    <HomeHero siteConfig={siteConfig} focusItems={focusItems}>
      <HomeStatusConsole
        siteUpdatedRelative={relativeDate(siteUpdatedDate)}
        liveProjects={liveProjects}
        plannedProjects={plannedProjects}
        externalLinks={externalLinks}
      />
    </HomeHero>
    <HomeCommand />
    <HomeProjects mainProject={mainProject} sideProjects={sideProjects} />
    <HomeNavigation items={navigationMatrix} />
    <HomeActivityNetwork updates={featuredUpdates} networkLinks={networkLinks} />
    <HomeRoadmap phases={phases} />
  </main>

  <script is:inline>
    document.documentElement.classList.add('is-home-page');
  </script>
</BaseLayout>
