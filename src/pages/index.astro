---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeCards, links, recentUpdates, siteConfig, sitePages } from '../data/site';
import { projectDetails } from '../data/projects';
import { relativeDate, siteUpdatedDate, todayDate } from '../data/time';

const pageCount = sitePages.length + projectDetails.length + 1;
const liveProjects = projectDetails.filter((p) => p.status === '已上线').length;
const plannedProjects = projectDetails.filter((p) => p.status !== '已上线').length;
const externalLinks = links.filter((link) => link.href.startsWith('http')).length;
const recentCount = recentUpdates.length;

const quickStats = [
  { value: pageCount, label: '静态页面', tone: 'blue' },
  { value: projectDetails.length, label: '项目记录', tone: 'violet' },
  { value: links.length, label: '公开入口', tone: 'green' },
  { value: recentCount, label: '近期更新', tone: 'amber' },
];

const focusItems = [
  { title: 'AI', desc: '工具、工作流与实验记录' },
  { title: 'Web', desc: 'Astro、前端与网站建设' },
  { title: 'Open', desc: 'GitHub 项目与长期维护' },
];

const quickActions = [
  { label: '查看项目', href: '/projects/', desc: '项目、工具、网站与实验' },
  { label: '现在在做', href: '/now/', desc: '最近状态与关注方向' },
  { label: '搜索站内', href: '/search/', desc: '页面、项目、链接与更新' },
  { label: '访问 GitHub', href: siteConfig.github, desc: '代码、仓库与实践记录' },
];

const featuredProjects = projectDetails.slice(0, 3);
const featuredLinks = links.slice(0, 6);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <section class="home-v2">
    <div class="home-v2-bg" aria-hidden="true"></div>

    <div class="home-v2-hero">
      <div class="hero-copy">
        <p class="hero-pill">
          <span class="hero-dot"></span>
          Build {todayDate} · {pageCount} pages · Astro / Cloudflare
        </p>

        <h1>
          Azek431 的
          <span>数字中枢</span>
        </h1>

        <p class="hero-lead">
          这里会集中整理我的项目、博客、学习记录、AI 实验和公开入口。
          我希望它不是一个堆满链接的导航页，而是一个能持续成长的个人网站系统。
        </p>

        <div class="hero-actions" aria-label="首页主要操作">
          <a class="ui-button ui-button-primary" href="/projects/">查看项目</a>
          <a class="ui-button ui-button-secondary" href={siteConfig.github}> GitHub </a>
          <button class="ui-button ui-button-ghost" type="button" data-copy-home>
            复制主页链接
          </button>
        </div>

        <div class="hero-focus-grid" aria-label="当前关注方向">
          {
            focusItems.map((item) => (
              <article>
                <strong>{item.title}</strong>
                <span>{item.desc}</span>
              </article>
            ))
          }
        </div>
      </div>

      <aside class="hero-console" aria-label="站点概览">
        <div class="console-top">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="console-body">
          <p class="console-label">site.status</p>
          <h2>Running</h2>

          <dl>
            <div>
              <dt>Last update</dt>
              <dd>{siteUpdatedDate} · {relativeDate(siteUpdatedDate)}</dd>
            </div>
            <div>
              <dt>Live projects</dt>
              <dd>{liveProjects} online / {plannedProjects} planned</dd>
            </div>
            <div>
              <dt>External links</dt>
              <dd>{externalLinks} public entries</dd>
            </div>
            <div>
              <dt>Stack</dt>
              <dd>Astro · TypeScript · CSS</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>

    <div class="home-stats-v2" aria-label="站点数据概览">
      {
        quickStats.map((stat) => (
          <article data-tone={stat.tone}>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-v2">
    <div class="section-head-v2">
      <p>Navigation</p>
      <h2>主要入口</h2>
      <span>先让访问者快速知道可以去哪里，再慢慢展开更多内容。</span>
    </div>

    <div class="quick-action-grid">
      {
        quickActions.map((action) => (
          <a class="quick-action-card" href={action.href}>
            <span>{action.label}</span>
            <small>{action.desc}</small>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section-v2">
    <div class="section-head-v2">
      <p>Projects</p>
      <h2>项目精选</h2>
      <span>把当前最重要的项目放到首页，让主站更像作品集入口。</span>
    </div>

    <div class="project-showcase">
      {
        featuredProjects.map((project) => (
          <article class="project-showcase-card" style={`--project-accent: ${project.accent}`}>
            <div>
              <p>{project.category}</p>
              <h3>{project.title}</h3>
              <span>{project.status}</span>
            </div>

            <p>{project.description}</p>

            <ul>
              {project.tags.slice(0, 3).map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>

            <a href={`/projects/${project.slug}/`}>查看详情 →</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-v2 split-v2">
    <div>
      <div class="section-head-v2">
        <p>Updates</p>
        <h2>最近更新</h2>
        <span>用时间线记录主站和项目的持续变化。</span>
      </div>

      <div class="update-list-v2">
        {
          recentUpdates.map((update) => (
            <a href={update.href}>
              <time>
                {update.date} · {relativeDate(update.date)}
              </time>
              <strong>{update.title}</strong>
              <span>{update.desc}</span>
            </a>
          ))
        }
      </div>
    </div>

    <aside class="nexus-card">
      <p>Public Links</p>
      <h2>公开入口</h2>
      <span> 这里聚合 GitHub、项目、RSS、Sitemap 和后续更多公开内容。 </span>

      <div>
        {
          featuredLinks.map((link) => (
            <a href={link.href}>
              <strong>{link.name}</strong>
              <small>{link.category}</small>
            </a>
          ))
        }
      </div>
    </aside>
  </section>

  <section class="section-v2 ecosystem-v2">
    <div class="section-head-v2">
      <p>Roadmap</p>
      <h2>下一步会继续扩展</h2>
      <span>主站会继续连接博客、项目官网、实验工具和长期内容。</span>
    </div>

    <div class="ecosystem-grid">
      {
        homeCards.map((card) => (
          <a href={card.href}>
            <span>{card.status}</span>
            <strong>{card.title}</strong>
            <small>{card.description}</small>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    var copyButton = document.querySelector('[data-copy-home]');
    if (!copyButton) return;

    copyButton.addEventListener('click', function () {
      var url = window.location.origin + '/';

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function () {
          copyButton.textContent = '已复制';
          window.setTimeout(function () {
            copyButton.textContent = '复制主页链接';
          }, 1400);
        });
        return;
      }

      copyButton.textContent = url;
    });
  })();
</script>
