---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavCard from '../components/NavCard.astro';
import { homeCards, siteConfig } from '../data/site';
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <section class="hero">
    <p class="eyebrow">Personal Digital Space</p>

    <h1>你好，我是 Azek431。</h1>

    <p class="hero-text">
      这里是我的个人数字空间。我会在这里整理博客、项目、学习记录和一些有趣的实验，
      也会把项目入口、公开链接和个人内容统一导航到这里。
    </p>

    <div class="actions">
      <a class="button primary" href="/projects/">查看项目</a>
      <a class="button secondary" href={siteConfig.github} target="_blank" rel="noreferrer">
        访问 GitHub
      </a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Navigation</p>
      <h2>主站导航</h2>
      <p>这个主站会作为我的长期入口，用来连接博客、项目、文档、实验内容和其他公开页面。</p>
    </div>

    <div class="cards">
      {
        homeCards.map((item) => (
          <NavCard
            title={item.title}
            description={item.description}
            href={item.href}
            status={item.status}
          />
        ))
      }
    </div>
  </section>

  <section class="section about-preview">
    <div>
      <p class="eyebrow">About</p>
      <h2>我正在构建自己的个人网站生态。</h2>
    </div>

    <p>
      目前我关注 AI、网站搭建、GitHub 项目部署和软件开发。
      这个站点会从一个简单的主站开始，后续逐步扩展博客、项目展示、文档和实验工具。
    </p>
  </section>
</BaseLayout>
