---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { siteUpdatedDate } from '../data/time';

const workingOn = [
  {
    title: 'Azek431 Home 主站迭代',
    detail: '继续重构 UI、页面结构和视觉系统，让个人主站更像长期维护的数字中枢。',
    status: '进行中',
    tag: '主站',
  },
  {
    title: '设计系统收尾',
    detail: '整理颜色、卡片、按钮、页面布局和响应式规则，减少临时样式堆叠。',
    status: '进行中',
    tag: '设计',
  },
  {
    title: 'Blog 仓库搭建',
    detail: '准备让博客独立成仓库，并和主站保持清晰的入口关系。',
    status: '规划中',
    tag: '内容',
  },
  {
    title: 'AI 工作流实验',
    detail: '尝试把开发、整理、重构和资料沉淀流程接入 AI 辅助。',
    status: '探索中',
    tag: 'AI',
  },
];

const reading = [
  { title: 'Astro / 静态站点实践', kind: 'Web' },
  { title: '设计系统与视觉层级', kind: 'Design' },
  { title: 'AI 编程工作流', kind: 'AI' },
  { title: 'GitHub 项目维护方式', kind: 'Open' },
];

const stack = [
  { name: 'Astro', role: '主站框架' },
  { name: 'Cloudflare Pages', role: '托管和 CDN' },
  { name: 'GitHub', role: '代码和版本记录' },
  { name: 'VS Code', role: '日常开发' },
  { name: 'pnpm', role: '包管理' },
  { name: 'Prettier', role: '格式化' },
];
---

<BaseLayout title="Now · Azek431" description="Azek431 最近正在做的事情、关注方向和日常工具。">
  <Breadcrumb items={[{ label: 'Now', href: '/now/' }]} />

  <section class="page-v2-hero now-hero-v2">
    <div>
      <p class="page-v2-kicker">Now</p>
      <h1>现在在做的事</h1>
      <p>
        这一页记录我最近关注的方向、正在做的项目、最近读到的内容和日常使用的工具。 它比 About
        更具体，比 Blog 更轻量。
      </p>
    </div>

    <div class="now-status-v2">
      <article>
        <span>最近更新</span>
        <strong>{siteUpdatedDate}</strong>
      </article>
      <article>
        <span>地点</span>
        <strong>线上 / GitHub</strong>
      </article>
      <article>
        <span>方向</span>
        <strong>Web · AI · Open</strong>
      </article>
    </div>
  </section>

  <section class="section-v2 split-v2">
    <div>
      <div class="section-head-v2">
        <p>Working On</p>
        <h2>正在推进</h2>
        <span>这几条是当前优先级最高的方向。</span>
      </div>

      <div class="now-work-list-v2">
        {
          workingOn.map((item) => (
            <article>
              <div>
                <span>{item.tag}</span>
                <small>{item.status}</small>
              </div>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </article>
          ))
        }
      </div>
    </div>

    <aside class="nexus-card now-side-v2">
      <p>Reading</p>
      <h2>最近关注</h2>
      <span>不一定都是技术，也可能是设计、产品、开发流程或项目维护方法。</span>

      <div>
        {
          reading.map((item) => (
            <a href="/search/">
              <strong>{item.title}</strong>
              <small>{item.kind}</small>
            </a>
          ))
        }
      </div>
    </aside>
  </section>

  <section class="section-v2">
    <div class="section-head-v2">
      <p>Stack</p>
      <h2>日常工具</h2>
      <span>稳定、长期、可维护优先。</span>
    </div>

    <div class="tool-grid-v2">
      {
        stack.map((item) => (
          <article>
            <strong>{item.name}</strong>
            <span>{item.role}</span>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
