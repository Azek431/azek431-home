---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteUpdatedDate } from '../data/time';

const workingOn = [
  {
    title: 'Azek431 Home 主站迭代',
    detail: '继续重构 UI、页面结构和视觉系统，让个人主站更像长期维护的数字中枢。',
    status: '进行中',
    tag: '主站',
  },
  {
    title: '设计系统收尾',
    detail: '整理颜色、卡片、按钮、页面布局和响应式规则，减少临时样式堆叠。',
    status: '进行中',
    tag: '设计',
  },
  {
    title: 'Blog 仓库搭建',
    detail: '准备让博客独立成仓库，并和主站保持清晰的入口关系。',
    status: '规划中',
    tag: '内容',
  },
  {
    title: 'AI 工作流实验',
    detail: '尝试把开发、整理、重构和资料沉淀流程接入 AI 辅助。',
    status: '探索中',
    tag: 'AI',
  },
];

const reading = [
  { title: 'Astro / 静态站点实践', kind: 'Web' },
  { title: '设计系统与视觉层级', kind: 'Design' },
  { title: 'AI 编程工作流', kind: 'AI' },
  { title: 'GitHub 项目维护方式', kind: 'Open' },
];

const stack = [
  { name: 'Astro', role: '主站框架' },
  { name: 'Cloudflare Pages', role: '托管和 CDN' },
  { name: 'GitHub', role: '代码和版本记录' },
  { name: 'VS Code', role: '日常开发' },
  { name: 'pnpm', role: '包管理' },
  { name: 'Prettier', role: '格式化' },
];
---

<BaseLayout title="Now · Azek431" description="Azek431 最近正在做的事情、关注方向和日常工具。">
  <section class="section">
    <!-- Hero -->
    <div class="section-heading">
      <p class="eyebrow">Now</p>
      <h1>现在在做的事</h1>
      <p>
        这一页记录我最近关注的方向、正在做的项目、最近读到的内容和日常使用的工具。它比 About
        更具体，比 Blog 更轻量。
      </p>
    </div>

    <!-- Status -->
    <div class="projects-summary">
      <div class="projects-summary__item">
        <span>最近更新</span>
        <strong>{siteUpdatedDate}</strong>
      </div>
      <div class="projects-summary__item">
        <span>地点</span>
        <strong>线上 / GitHub</strong>
      </div>
      <div class="projects-summary__item">
        <span>方向</span>
        <strong>Web · AI · Open</strong>
      </div>
    </div>

    <!-- Working On -->
    <div class="section-heading">
      <p class="eyebrow">Working On</p>
      <h2>正在推进</h2>
      <p style="font-size: var(--text-sm); color: var(--color-text-muted);">
        这几条是当前优先级最高的方向。
      </p>
    </div>

    <div class="now-list">
      {
        workingOn.map((item) => (
          <div class="now-item">
            <div style="display: flex; gap: var(--space-2); margin-bottom: var(--space-2);">
              <span class="tag">{item.tag}</span>
              <span class="tag tag-accent">{item.status}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </div>
        ))
      }
    </div>

    <!-- Reading -->
    <div class="section-heading">
      <p class="eyebrow">Reading</p>
      <h2>最近关注</h2>
      <p style="font-size: var(--text-sm); color: var(--color-text-muted);">
        不一定都是技术，也可能是设计、产品、开发流程或项目维护方法。
      </p>
    </div>

    <div class="card-grid">
      {
        reading.map((item) => (
          <a class="card" href="/search/" style="text-decoration: none;">
            <h3>{item.title}</h3>
            <span class="tag tag-accent">{item.kind}</span>
          </a>
        ))
      }
    </div>

    <!-- Stack -->
    <div class="section-heading">
      <p class="eyebrow">Stack</p>
      <h2>日常工具</h2>
      <p style="font-size: var(--text-sm); color: var(--color-text-muted);">
        稳定、长期、可维护优先。
      </p>
    </div>

    <div class="card-grid">
      {
        stack.map((item) => (
          <div class="card">
            <strong style="font-size: var(--text-base);">{item.name}</strong>
            <span style="font-size: var(--text-sm); color: var(--color-text-muted);">
              {item.role}
            </span>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
