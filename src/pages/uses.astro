---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteUpdatedDate } from '../data/time';

const categories = [
  {
    title: '开发环境',
    desc: '主站开发、代码编辑和终端工作流。',
    items: [
      { name: 'VS Code', detail: '主力编辑器，负责 Astro、TypeScript、CSS 和 Markdown。' },
      { name: 'Windows Terminal', detail: '日常 PowerShell / pnpm / git 命令入口。' },
      { name: 'Git', detail: '记录每一次改动，保持项目可回溯。' },
    ],
  },
  {
    title: '网站技术',
    desc: '个人主站的核心技术栈。',
    items: [
      { name: 'Astro', detail: '静态生成、组件化和极少运行时 JS。' },
      { name: 'Cloudflare Pages', detail: '自动部署、CDN 和正式域名托管。' },
      { name: 'pnpm', detail: '快速、稳定、适合长期维护的包管理。' },
    ],
  },
  {
    title: 'AI / 自动化',
    desc: '辅助开发、分析和内容整理。',
    items: [
      { name: 'ChatGPT', detail: '辅助规划、重构、审查和文案整理。' },
      { name: 'Codex', detail: '辅助代码理解、修改和项目迭代。' },
      { name: 'GitHub Actions', detail: '用于自动检查和部署流程。' },
    ],
  },
];

const totalItems = categories.reduce((sum, category) => sum + category.items.length, 0);
---

<BaseLayout
  title="Uses · Azek431"
  description="Azek431 日常使用的硬件、软件、开发工具和网站技术栈。"
>
  <section class="section">
    <!-- Hero -->
    <div class="section-heading">
      <p class="eyebrow">Uses</p>
      <h1>我在用什么</h1>
      <p>这里记录我搭建主站、写代码、托管内容和整理项目时常用的工具。工具会变化，但原则是长期、稳定、清晰和可维护。</p>
    </div>

    <!-- Stats -->
    <div class="projects-summary">
      <div class="projects-summary__item">
        <strong>{categories.length}</strong>
        <span>工具分类</span>
      </div>
      <div class="projects-summary__item">
        <strong>{totalItems}</strong>
        <span>常用工具</span>
      </div>
      <div class="projects-summary__item">
        <strong>{siteUpdatedDate}</strong>
        <span>最近更新</span>
      </div>
      <div class="projects-summary__item">
        <strong>Stable</strong>
        <span>使用原则</span>
      </div>
    </div>

    <!-- Categories -->
    {
      categories.map((category) => (
        <div style="margin-bottom: var(--space-10);">
          <div class="section-heading">
            <p class="eyebrow">{category.title}</p>
            <h2>{category.desc}</h2>
          </div>

          <div class="card-grid">
            {category.items.map((item) => (
              <div class="card">
                <strong style="font-size: var(--text-base);">{item.name}</strong>
                <p>{item.detail}</p>
              </div>
            ))}
          </div>
        </div>
      ))
    }

    <!-- Footer note -->
    <div class="about-narrative">
      <p>装备会变，原则不变。我更在意一套工具能不能长期稳定地服务项目，而不是追求看起来很复杂的配置。</p>
      <div style="display: flex; gap: var(--space-3); margin-top: var(--space-4);">
        <a class="button button-primary" href="/colophon/">查看设计说明</a>
        <a class="button button-secondary" href="/now/">回到 Now</a>
      </div>
    </div>
  </section>
</BaseLayout>
